 /* Removed strict brutalist global transitions override to allow subtle editorial interactions */
+
+
+/* 5. Refinamento de cores - Livro Impresso Clássico */
+/* Suavizando o contraste e adotando tons de tinta oxidada e papel antigo,
+   mas com um toque mais profundo (darker) para o accent-color. */
+:root {
+  --bg-color: #f4f1ea; /* Papel de livro antigo um pouco mais escuro */
+  --text-color: #2c2825; /* Tinta carvão menos absoluta */
+  --accent-color: #8a1f16; /* Vermelho rubrica clássico, mais seco */
+  --meta-color: #6d665f; /* Cinza chumbo quente */
+  --divider-color: rgba(44, 40, 37, 0.15); /* Divisões um pouco mais densas */
+  --sand-bg: #ece9e1;
+}
+
+[data-theme="dark"] {
+  --bg-color: #1a1817; /* Fundo mais escuro e quente */
+  --text-color: #d8d4cb; /* Texto não tão branco */
+  --accent-color: #a62a1f; /* Vermelho sangue seco para dark mode */
+  --meta-color: #8c8880;
+  --divider-color: rgba(216, 212, 203, 0.15);
+  --sand-bg: #262422;
+}
