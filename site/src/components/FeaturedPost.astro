---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-content">
    <div class="featured-header">
      <span class="featured-label">Última Carta</span>
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>— {autor}</span>}
    </div>
  </div>
</a>

<style>
  .featured-post {
    display: flex;
    position: relative;
    margin-bottom: 4rem;
    padding: 0;

    background-color: var(--bg-color) !important;
    border: 4px solid var(--text-color) !important;
    border-radius: 0 !important;
    box-shadow: 12px 12px 0 var(--text-color) !important;

    text-decoration: none;
    overflow: hidden;
    transform: none !important;
    transition: transform 0s, box-shadow 0s, background-color 0s, color 0s !important;
  }

  :global([data-theme="dark"]) .featured-post {
    border: 4px solid var(--text-color) !important;
    box-shadow: 12px 12px 0 var(--accent-color) !important;
  }

  .featured-post:hover {
    transform: translate(-6px, -6px) !important;
    box-shadow: 18px 18px 0 var(--accent-color) !important;
    background-color: var(--text-color) !important;
    color: var(--bg-color) !important;
    border-color: var(--accent-color) !important;
  }



  .featured-content {
    flex-grow: 1;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 600px) {
    .featured-post {
      flex-direction: column;
    }
    .featured-content {
      padding: 1.5rem;
    }
  }

  .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    font-family: var(--font-meta);
  }

  .featured-label {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 900;
    color: var(--bg-color);
    background-color: var(--text-color);
    padding: 0.3rem 0.8rem;
    border: 3px solid var(--text-color);
    border-radius: 0;
  }

  .featured-post:hover .featured-label {
    background-color: var(--accent-color) !important;
    color: var(--text-color) !important;
    border-color: var(--text-color) !important;
  }

  time {
    font-size: 1rem;
    color: var(--text-color);
    font-weight: 900;
    letter-spacing: 0.05em;
  }

  .featured-post:hover time {
    color: var(--bg-color) !important;
  }

  .card-titulo {
    font-family: var(--font-meta);
    font-size: 3rem;
    margin: 1rem 0 1.5rem;
    color: var(--text-color);
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
  }

  .featured-post:hover .card-titulo {
    color: var(--bg-color) !important;
  }

  .card-excerpt {
    font-family: var(--font-body);
    font-size: 1.3rem;
    color: var(--text-color);
    line-height: 1.5;
    font-weight: 600;
    margin: 0 0 1.5rem;
  }

  .featured-post:hover .card-excerpt {
    color: var(--bg-color) !important;
  }

  .card-meta {
    display: flex;
    justify-content: flex-end;
    font-family: var(--font-meta);
    font-size: 1.2rem;
    color: var(--text-color);
    font-weight: 900;
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 4px solid var(--text-color);
  }

  .featured-post:hover .card-meta {
    color: var(--bg-color) !important;
    border-top: 4px solid var(--bg-color) !important;
  }

  .card-autor {
    font-weight: 900;
    color: var(--text-color);
    font-style: normal;
    text-transform: uppercase;
  }

  .featured-post:hover .card-autor {
    color: var(--bg-color) !important;
  }

</style>
