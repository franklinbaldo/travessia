---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-label">Última Carta</div>
  <div class="featured-content">
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>{autor}</span>}
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
  </div>
</a>

<style>
  .featured-post {
    --print-bg: #fdfbf7;
    --print-ink: #0a0a0a;
    --print-meta: #4a4a4a;

    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 2rem;
    position: relative;
    margin-bottom: 3rem;
    padding: 2.5rem 2rem;
    border: 1px solid var(--print-ink);
    border-top: 6px solid var(--print-ink);
    border-bottom: 6px solid var(--print-ink);
    border-radius: 0;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    background: var(--print-bg);
  }

  :global([data-theme="dark"]) .featured-post {
    --print-bg: #111111;
    --print-ink: #e8e6e3;
    --print-meta: #aaaaaa;
  }

  @media (max-width: 600px) {
    .featured-post {
      grid-template-columns: 1fr;
      padding: 1.5rem;
      gap: 1rem;
    }
  }

  .featured-post:hover {
    background-color: var(--print-ink);
    color: var(--print-bg);
  }

  .featured-post:hover .card-titulo,
  .featured-post:hover .card-excerpt,
  .featured-post:hover .card-autor,
  .featured-post:hover .featured-label,
  .featured-post:hover .card-meta,
  .featured-post:hover time {
    color: var(--print-bg);
    border-color: var(--print-bg);
  }

  .featured-label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--print-ink);
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--print-ink);
    padding-right: 1.5rem;
  }

  @media (max-width: 600px) {
    .featured-label {
      writing-mode: horizontal-tb;
      transform: none;
      border-right: none;
      border-bottom: 1px solid var(--print-ink);
      padding-right: 0;
      padding-bottom: 1rem;
      font-size: 1.1rem;
    }
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-titulo {
    font-family: var(--font-body);
    font-size: 2.5rem;
    margin: 0 0 1rem;
    color: var(--print-ink);
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .card-excerpt {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--print-ink);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .card-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--print-meta);
    font-weight: 600;
    border-top: 1px solid var(--print-ink);
    padding-top: 1rem;
  }

  .card-autor {
    font-weight: 700;
    color: var(--print-ink);
  }

  time {
    color: var(--print-meta);
  }
</style>
