---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-content">
    <div class="featured-header">
      <span class="featured-label">Última Carta</span>
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>— {autor}</span>}
    </div>
  </div>
</a>

<style>
  /* Refinement for classic print and performance */
  .featured-post {
    display: block;
    margin-bottom: 4rem;
    padding: 3rem 0 4rem;
    text-decoration: none;
    border-top: 1px solid var(--divider-color);
    border-bottom: 1px solid var(--divider-color);
    color: var(--text-color);
  }

  .featured-post:hover .card-titulo {
    color: var(--accent-color);
  }

  .featured-content {
    display: flex;
    flex-direction: column;
  }

  .featured-header {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
    margin-bottom: 2rem;
    font-family: var(--font-meta);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    color: var(--meta-color);
  }

  .featured-label {
    font-weight: 600;
    color: var(--text-color);
  }

  .card-titulo {
    font-family: var(--font-body);
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin: 0 0 1.5rem;
    color: var(--text-color);
    line-height: 1.1;
    font-weight: normal;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .card-excerpt {
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 2vw, 1.3rem);
    color: var(--text-color);
    line-height: 1.6;
    margin: 0 0 2rem;
    max-width: 65ch;
  }

  .card-meta {
    font-family: var(--font-meta);
    font-size: 0.9rem;
    color: var(--meta-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
