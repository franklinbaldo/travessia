---
import { formatDate } from "../lib/utils";
interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}
const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---
<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-content">
    <div class="featured-header">
      <span class="featured-label">Última Carta</span>
      {data && <><span class="sr-only">Publicado em </span><time datetime={data.toISOString()}>{formatDate(data)}</time></>}
    </div>
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}><span aria-hidden="true">—</span> <span class="sr-only">por </span>{autor}</span>}
    </div>
  </div>
</a>
<style>
  /*
   * Craig Mod - Sessão 352
   * Focus: Layout e Estrutura
   * Inspiração: Radical Flatness / Revista literária
   * Restrição: nenhuma mudança estrutural — só refinamento
   */
  .featured-post {
    display: block;
    margin-bottom: 4rem;
    padding: 0 0 4rem 0 !important; /* Remove tight box padding */
    text-decoration: none;
    background-color: transparent !important; /* Remove inverted background block */
    color: var(--text-color) !important;
    border: none !important;
    border-bottom: 2px solid var(--text-color) !important; /* Anchor with a single strong line */
    position: relative;
    transition: none;
  }
  :global(.featured-post:hover) {
    transform: none !important;
    box-shadow: none;
    background-color: transparent !important;
  }
  .featured-post::before {
    display: none !important;
  }
  .featured-content {
    display: flex;
    flex-direction: column;
  }
  .featured-header {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
    margin-bottom: 1.5rem;
    font-family: var(--font-meta);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    color: var(--meta-color);
  }
  .featured-label {
    font-weight: 700;
    color: var(--accent-color);
    background-color: transparent; /* Remove label pill */
    padding: 0;
    border-radius: 0;
  }
  :global(.featured-post:hover) .featured-label {
    color: var(--text-color);
  }
  .card-titulo {
    font-family: var(--font-body);
    font-size: clamp(3.5rem, 8vw, 6rem); /* Increase scale to compensate for lack of background */
    margin: 0 0 1rem;
    color: var(--text-color) !important;
    line-height: 0.95;
    font-weight: normal;
    letter-spacing: -0.04em;
    transition: none;
  }
  :global(.featured-post:hover) .card-titulo {
    color: var(--accent-color) !important;
  }
  .card-excerpt {
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    color: var(--text-color) !important;
    line-height: 1.6;
    margin: 0 0 2rem;
    max-width: 55ch;
  }
  .card-meta {
    font-family: var(--font-meta);
    font-size: 0.95rem;
    color: var(--meta-color) !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  :global(.featured-post:hover) .card-meta span {
    color: var(--accent-color) !important;
  }
</style>
