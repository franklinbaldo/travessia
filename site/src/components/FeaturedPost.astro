---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-label">Última Carta</div>
  <div class="featured-content">
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>{autor}</span>}
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
  </div>
</a>

<style>
  .featured-post {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 2rem;
    position: relative;
    margin-bottom: 2rem;
    padding: 2rem;
    border: 4px solid var(--text-color);
    border-radius: 0;
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    background: var(--bg-color);
  }

  @media (max-width: 600px) {
    .featured-post {
      grid-template-columns: 1fr;
      padding: 1.5rem;
      gap: 1rem;
    }
  }

  .featured-post.autor-border-rio {
    border-color: var(--secondary-color);
  }

  .featured-post.autor-border-ted {
    border-color: var(--text-color);
  }

  .featured-post:hover {
    background-color: var(--text-color);
    border-color: var(--text-color);
    color: var(--bg-color);
    opacity: 1;
  }

  .featured-post:hover .card-titulo,
  .featured-post:hover .card-excerpt,
  .featured-post:hover .card-autor,
  .featured-post:hover .featured-label,
  .featured-post:hover .card-meta {
    color: var(--bg-color);
  }

  .featured-label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-meta);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-color);
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 4px solid var(--text-color);
    padding-right: 1.5rem;
  }

  @media (max-width: 600px) {
    .featured-label {
      writing-mode: horizontal-tb;
      transform: none;
      border-right: none;
      border-bottom: 4px solid var(--text-color);
      padding-right: 0;
      padding-bottom: 1rem;
      font-size: 1rem;
    }
  }

  .featured-post.autor-border-rio .featured-label {
    color: var(--secondary-color);
    border-color: var(--secondary-color);
  }

  .featured-post.autor-border-ted .featured-label {
    color: var(--text-color);
    border-color: var(--text-color);
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-titulo {
    font-size: 2rem;
    margin: 0 0 1rem;
    color: var(--text-color);
    line-height: 1.2;
    font-weight: 800;
  }

  .card-excerpt {
    font-size: 1.1rem;
    color: var(--meta-color);
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }

  .card-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--meta-color);
    font-weight: 700;
  }

  .card-autor {
    font-weight: 700;
  }

  .card-autor.autor-rio {
    color: var(--secondary-color);
  }

  .card-autor.autor-ted {
    color: var(--meta-color);
  }
</style>
