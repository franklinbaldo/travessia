---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-label">Última Carta</div>
  <h2 class="card-titulo">{titulo}</h2>
  <p class="card-excerpt">{excerpt}</p>
  <div class="card-meta">
    {autor && <span class={`card-autor autor-${autorClasse}`}>{autor}</span>}
    {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
  </div>
</a>

<style>
  .featured-post {
    display: block;
    position: relative;
    margin-bottom: 2rem;
    padding: 1.75rem 2rem; border: 2px solid var(--text-color); border-radius: 0;
    text-decoration: none; border-left: 2px solid var(--text-color);
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }



  .featured-post.autor-border-rio {
    border-left-color: var(--secondary-color);
  }

  .featured-post.autor-border-ted {
    border-left-color: var(--water-border);
  }

  .featured-post:hover {
    background-color: var(--text-color);
    border-color: var(--text-color);
    color: var(--bg-color);

    opacity: 1;
  }

  .featured-post:hover .card-titulo,
  .featured-post:hover .card-excerpt,
  .featured-post:hover .card-autor,
  .featured-post:hover .featured-label,
  .featured-post:hover .card-meta {
    color: var(--bg-color);
  }

  .featured-label {
    font-family: var(--font-meta);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--meta-color);
    margin-bottom: 0.6rem;
  }

  .card-titulo {
    font-size: 1.45rem;
    margin: 0 0 0.5rem;
    color: var(--text-color);
    line-height: 1.3;
    font-weight: 700;
  }

  .card-excerpt {
    font-size: 0.95rem;
    color: var(--meta-color);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }

  .card-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--meta-color);
  }

  .card-autor {
    font-weight: 600;
  }

  .card-autor.autor-rio {
    color: var(--secondary-color);
  }

  .card-autor.autor-ted {
    color: var(--meta-color);
  }
</style>
