---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-content">
    <div class="featured-header">
      <span class="featured-label">Última Carta</span>
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>— {autor}</span>}
    </div>
  </div>
</a>

<style>
  .featured-post {
    display: flex;
    position: relative;
    margin-bottom: 4rem;
    padding: 0;

    /* Contemporary literary magazine: stark contrast block */
    background-color: var(--text-color) !important;
    color: var(--bg-color) !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;

    text-decoration: none;
    overflow: hidden;
    transform: none !important;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.4s ease !important;
  }

  :global([data-theme="dark"]) .featured-post {
    background-color: var(--text-color) !important;
  }

  .featured-post:hover {
    transform: translateY(-4px) !important;
    background-color: var(--accent-color) !important;
    color: var(--bg-color) !important;
  }

  .featured-content {
    flex-grow: 1;
    padding: 3rem;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 600px) {
    .featured-post {
      flex-direction: column;
    }
    .featured-content {
      padding: 2rem;
    }
  }

  .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    font-family: var(--font-meta);
    border-bottom: 1px solid var(--bg-color);
    padding-bottom: 1rem;
  }

  .featured-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: var(--text-color);
    background-color: var(--bg-color);
    padding: 0.4rem 1rem;
    border: none;
    border-radius: 20px;
  }

  .featured-post:hover .featured-label {
    background-color: var(--bg-color) !important;
    color: var(--accent-color) !important;
  }

  time {
    font-size: 0.9rem;
    color: var(--bg-color);
    font-weight: 600;
    letter-spacing: 0.05em;
    opacity: 0.9;
  }

  .featured-post:hover time {
    color: var(--bg-color) !important;
    opacity: 1;
  }

  .card-titulo {
    font-family: var(--font-meta);
    font-size: 3.5rem;
    margin: 1rem 0 1.5rem;
    color: var(--bg-color);
    line-height: 1.1;
    font-weight: 800;
    text-transform: none;
    letter-spacing: -0.02em;
  }

  .featured-post:hover .card-titulo {
    color: var(--bg-color) !important;
  }

  .card-excerpt {
    font-family: var(--font-body);
    font-size: 1.4rem;
    color: var(--bg-color);
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 2rem;
    opacity: 0.9;
  }

  .featured-post:hover .card-excerpt {
    color: var(--bg-color) !important;
    opacity: 1;
  }

  .card-meta {
    display: flex;
    justify-content: flex-end;
    font-family: var(--font-meta);
    font-size: 1.1rem;
    color: var(--bg-color);
    font-weight: 600;
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .featured-post:hover .card-meta {
    color: var(--bg-color) !important;
    border-top: 1px solid rgba(255, 255, 255, 0.4) !important;
  }

  .card-autor {
    font-weight: 700;
    color: var(--bg-color);
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .featured-post:hover .card-autor {
    color: var(--bg-color) !important;
  }
</style>
