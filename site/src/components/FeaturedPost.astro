---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-content">
    <div class="featured-header">
      <span class="featured-label">Última Carta</span>
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>— {autor}</span>}
    </div>
  </div>
</a>

<style>
  /*
   * Craig Mod - Sessão 321
   * Focus: Cor e contraste
   * Inspiração: Revista literária contemporânea
   * Restrição: Focar numa única página/componente (FeaturedPost)
   *
   * Transformando o Featured Post em um bloco sólido de cor invertida (high contrast).
   */
  .featured-post {
    display: block;
    margin-bottom: 4rem;
    padding: 4rem 3rem !important;
    text-decoration: none;
    background-color: var(--text-color) !important;
    color: var(--bg-color) !important;
    border: none !important;
    position: relative;
    transition: background-color 0s !important;
  }

  /* Override brutalist global pop-out for this specific component to maintain the lit-mag elegance */
  :global(.featured-post:hover) {
    transform: none !important;
    box-shadow: none !important;
    background-color: var(--accent-color) !important;
    color: var(--bg-color) !important;
  }

  .featured-post::before {
    display: none !important;
  }

  .featured-content {
    display: flex;
    flex-direction: column;
  }

  .featured-header {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
    margin-bottom: 2.5rem;
    font-family: var(--font-meta);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    color: var(--bg-color);
    opacity: 0.9;
  }

  .featured-label {
    font-weight: 700;
    color: var(--text-color);
    background-color: var(--bg-color);
    padding: 0.3rem 0.8rem;
    border-radius: 2px;
  }

  :global(.featured-post:hover) .featured-label {
    color: var(--accent-color);
  }

  .card-titulo {
    font-family: var(--font-body);
    font-size: clamp(2.5rem, 6vw, 5rem);
    margin: 0 0 1.5rem;
    color: var(--bg-color) !important;
    line-height: 1.05;
    font-weight: normal;
    letter-spacing: -0.02em;
    transition: none !important;
  }

  .card-excerpt {
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    color: var(--bg-color) !important;
    line-height: 1.5;
    margin: 0 0 2rem;
    max-width: 55ch;
    opacity: 0.9;
  }

  .card-meta {
    font-family: var(--font-meta);
    font-size: 0.95rem;
    color: var(--bg-color) !important;
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
