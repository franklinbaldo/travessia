---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-content">
    <div class="featured-header">
      <span class="featured-label">Última Carta</span>
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>— {autor}</span>}
    </div>
  </div>
</a>

<style>
  /* Constraint: Web Brutalista Pura + Microinterações */
  /* Eliminar complacência editorial e adotar atrito imediato */
  .featured-post {
    display: block;
    margin-bottom: 4rem;
    text-decoration: none;
    border-top: 2px solid var(--text-color);
    border-bottom: 2px solid var(--text-color);
    color: var(--text-color) !important;
    padding: 3rem 1rem;
    transition: none !important; /* Brutalist binary snap */
    background-color: transparent !important;
    transform: none;
  }

  .featured-post {
    position: relative;
    z-index: 1;
  }

  .featured-post::before {
    display: none !important; /* Remove fluent opacity background fills */
  }


  .featured-post:hover {
    background-color: var(--text-color) !important; /* Complete blackout */
    color: var(--bg-color) !important;
    border-color: var(--text-color);
    transform: translate(-10px, -10px) !important; /* Aggressive shift */
    box-shadow: 10px 10px 0 var(--accent-color) !important; /* Sharp toxic drop shadow */
    transition: none !important;
  }

  .featured-post:hover .card-titulo,
  .featured-post:hover .card-excerpt,
  .featured-post:hover .featured-label,
  .featured-post:hover time,
  .featured-post:hover .card-meta,
  .featured-post:hover .card-autor {
    color: var(--bg-color) !important;
    transition: none !important;
  }

  .featured-post .card-titulo,
  .featured-post .card-excerpt,
  .featured-post .featured-label,
  .featured-post time,
  .featured-post .card-meta,
  .featured-post .card-autor {
    transition: none !important;
  }

  .featured-content {
    display: flex;
    flex-direction: column;
  }

  .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
    font-family: var(--font-meta);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }

  .featured-label {
    font-weight: 700;
    color: var(--text-color);
  }

  time {
    color: var(--meta-color);
  }

  .card-titulo {
    font-family: var(--font-body);
    font-size: clamp(3rem, 6vw, 4.5rem);
    margin: 0 0 1.5rem;
    color: var(--text-color) !important;
    line-height: 1.05;
    font-weight: normal;
    letter-spacing: -0.01em;
  }

  .card-excerpt {
    font-family: var(--font-meta);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--meta-color) !important;
    line-height: 1.5;
    margin: 0 0 2rem;
    max-width: 800px;
    font-weight: normal;
  }

  .card-meta {
    font-family: var(--font-meta);
    font-size: 0.9rem;
    color: var(--text-color) !important;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-autor {
    color: var(--text-color) !important;
  }
</style>
