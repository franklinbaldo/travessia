---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  autorClasse?: string;
  autor?: string;
  excerpt: string;
  data?: Date;
}

const { url, titulo, autorClasse, autor, excerpt, data } = Astro.props;
---

<a
  href={url}
  class={`featured-post autor-border-${autorClasse}`}
  data-autor={autorClasse}
>
  <div class="featured-content">
    <div class="featured-header">
      <span class="featured-label">Última Carta</span>
      {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    </div>
    <h2 class="card-titulo">{titulo}</h2>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">
      {autor && <span class={`card-autor autor-${autorClasse}`}>— {autor}</span>}
    </div>
  </div>
</a>

<style>
  /* Constraint: Performance e Simplicidade + Revista Literária Contemporânea */
  /* Removemos transitions complexas, transformações e bg colors pesados.
     Foco puramente tipográfico. */
  .featured-post {
    display: block;
    margin-bottom: 4rem;
    text-decoration: none;
    border-top: 4px solid var(--text-color);
    border-bottom: 4px solid var(--text-color);
    color: var(--text-color) !important;
    padding: 3rem 0;
    transition: opacity 0.2s ease;
    background-color: transparent !important;
  }

  .featured-post:hover {
    opacity: 0.6;
    background-color: transparent !important;
    color: var(--text-color) !important;
    transform: none !important;
  }

  .featured-content {
    display: flex;
    flex-direction: column;
  }

  .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
    font-family: var(--font-meta);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }

  .featured-label {
    font-weight: 700;
    color: var(--text-color);
  }

  time {
    color: var(--meta-color);
  }

  .card-titulo {
    font-family: var(--font-body);
    font-size: clamp(3rem, 6vw, 4.5rem);
    margin: 0 0 1.5rem;
    color: var(--text-color) !important;
    line-height: 1.05;
    font-weight: normal;
    letter-spacing: -0.01em;
  }

  .card-excerpt {
    font-family: var(--font-meta);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--meta-color) !important;
    line-height: 1.5;
    margin: 0 0 2rem;
    max-width: 800px;
    font-weight: normal;
  }

  .card-meta {
    font-family: var(--font-meta);
    font-size: 0.9rem;
    color: var(--text-color) !important;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-autor {
    color: var(--text-color) !important;
  }
</style>
