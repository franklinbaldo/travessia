---
import { formatDate } from "../lib/utils";
interface Props {
  url: string;
  titulo: string;
  tipo: string;
  tipoLabel: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  data?: Date;
}
const {
  url,
  titulo,
  tipo,
  tipoLabel,
  subtitulo,
  autor,
  autorClasse,
  excerpt,
  data,
} = Astro.props;
---
<a href={url} class="blog-card" data-tipo={tipo} data-autor={autorClasse}>
  <h2 class="card-titulo">{titulo}</h2>
  {subtitulo && <p class="card-subtitulo">{subtitulo}</p>}
  <p class="card-excerpt">{excerpt}</p>
  <div class="card-meta">
    <span class="card-tipo">{tipoLabel}</span>{data && <>, <time datetime={data.toISOString()}><span class="sr-only">Publicado em </span>{formatDate(data)}</time></>}{autor && <>. <span class={`card-autor autor-${autorClasse}`}><span class="sr-only">por </span>{autor}</span></>}
  </div>
</a>
<style>
  /* RADICAL FLATNESS (Sessão 352 - Layout e Estrutura) */
  .blog-card {
    display: block;
    text-decoration: none;
    padding: 0 0 2rem 0 !important;
    margin-bottom: 2rem !important;
    border: none !important;
    border-bottom: 1px solid var(--text-color) !important;
    background-color: transparent !important;
    box-shadow: none !important;
    position: relative;
    transition: none !important;
    z-index: 1;
  }
  .blog-card:hover {
    background-color: transparent !important;
    transform: none; /* remove physical jump */
    box-shadow: none !important; /* remove shadow */
    z-index: 10;
  }
  .card-titulo {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-color);
    margin: 0 0 0.5rem 0;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .blog-card:hover .card-titulo {
    color: var(--accent-color) !important;
    background-color: transparent !important;
  }
  .card-subtitulo {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: bold;
    color: var(--text-color);
    font-size: 1.1rem;
    margin: 0 0 0.5rem 0;
    border-bottom: 2px solid var(--text-color);
    display: inline-block;
  }
  .card-excerpt {
    font-family: var(--font-meta);
    font-size: 1rem;
    color: var(--text-color);
    line-height: 1.4;
    margin: 0 0 1rem 0;
    max-width: 100%;
  }
  .card-meta {
    font-family: var(--font-meta) !important;
    font-size: 0.9rem !important;
    color: var(--meta-color) !important;
    margin: 0 !important;
    display: block !important;
    font-style: normal !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    font-weight: bold !important;
    border-top: none;
    padding-top: 0.5rem;
  }
  .card-meta span, .card-meta time {
    display: inline !important;
    font-family: var(--font-meta) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    font-weight: bold !important;
  }
  .card-meta::before {
    content: ""; /* remove prompt */
  }
  .card-tipo {
    color: var(--secondary-color) !important;
  }
  .blog-card:hover .card-tipo {
    color: var(--accent-color) !important;
  }
  .card-autor {
    color: var(--text-color) !important;
  }
  .blog-card:hover .card-autor {
    color: var(--accent-color) !important;
  }
  .blog-card:hover .card-excerpt,
  .blog-card:hover time,
  .blog-card:hover .card-subtitulo,
  .blog-card:hover .card-meta {
    color: var(--text-color) !important;
  }
</style>
