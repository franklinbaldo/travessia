---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  tipo: string;
  tipoLabel: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  data?: Date;
}

const {
  url,
  titulo,
  tipo,
  tipoLabel,
  subtitulo,
  autor,
  autorClasse,
  excerpt,
  data,
} = Astro.props;
---

<a href={url} class="blog-card" data-tipo={tipo} data-autor={autorClasse}>
  <h2 class="card-titulo">{titulo}</h2>
  {subtitulo && <p class="card-subtitulo">{subtitulo}</p>}
  <p class="card-excerpt">{excerpt}</p>
  <div class="card-meta">
    <span class="card-tipo">{tipoLabel}</span>
    {autor && <span class={`card-autor autor-${autorClasse}`}>/ {autor}</span>}
    {data && <time datetime={data.toISOString()}>/ {formatDate(data)}</time>}
  </div>
</a>

<style>
  .card-titulo {
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.6rem;
    margin: 0 0 0.75rem;
    color: var(--text-color);
    line-height: 1.2;
    font-weight: normal;
    letter-spacing: -0.02em;
  }

  .card-subtitulo {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: var(--text-color);
    font-size: 1.1rem;
    margin: 0 0 1rem;
  }

  .card-excerpt {
    font-size: 1rem;
    color: var(--text-color);
    line-height: 1.6;
    margin: 0 0 1.2rem;
    opacity: 0.9;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--meta-color);
    margin-bottom: 1rem;
  }

  .card-tipo {
    font-weight: 700;
    color: var(--text-color);
  }

  .card-autor {
    color: var(--text-color);
    font-weight: bold;
  }

  .card-autor.autor-rio {
    color: var(--secondary-color);
  }

  /* Contemporary Literary Magazine constraints */
  .blog-card {
    display: flex;
    flex-direction: column;
    padding: 2rem 0 0 0 !important;
    margin-bottom: 3rem !important;
    border: none !important;
    border-top: 1px solid var(--text-color) !important;
    border-radius: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    transform: none !important;
    text-decoration: none;
    transition: opacity 0.3s ease !important;
  }

  .blog-card:hover {
    opacity: 0.7 !important;
    transform: none !important;
    box-shadow: none !important;
    background-color: transparent !important;
  }

  /* Adjust order for editorial look: Meta -> Title -> Excerpt */
  .blog-card .card-meta {
    order: 1;
  }
  .blog-card .card-titulo {
    order: 2;
  }
  .blog-card .card-subtitulo {
    order: 3;
  }
  .blog-card .card-excerpt {
    order: 4;
  }

  :global([data-theme="dark"]) .blog-card {
    border-top: 1px solid var(--text-color) !important;
  }

  .blog-card::after, .blog-card::before {
    display: none !important;
  }

</style>
