---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  tipo: string;
  tipoLabel: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  data?: Date;
}

const {
  url,
  titulo,
  tipo,
  tipoLabel,
  subtitulo,
  autor,
  autorClasse,
  excerpt,
  data,
} = Astro.props;
---

<a href={url} class="blog-card" data-tipo={tipo} data-autor={autorClasse}>
  <h2 class="card-titulo">{titulo}</h2>
  {subtitulo && <p class="card-subtitulo">{subtitulo}</p>}
  <p class="card-excerpt">{excerpt}</p>
  <div class="card-meta">
    <span class="card-tipo">{tipoLabel}</span>{data && <>, <time datetime={data.toISOString()}>{formatDate(data)}</time></>}{autor && <>. <span class={`card-autor autor-${autorClasse}`}>{autor}</span></>}
  </div>
</a>


<style>
  .blog-card {
    display: block;
    text-decoration: none;
    padding: 2.5rem 2rem !important;
    margin-bottom: 0 !important;
    border: none !important;
    border-bottom: 1px solid var(--divider-color) !important;
    background-color: transparent !important;
    box-shadow: none !important;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1), border-color 0.4s ease;
  }

  .blog-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: var(--sand-bg);
    opacity: 0;
    z-index: -1;
    transform: scale(0.98);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  }

  :global([data-theme="dark"]) .blog-card::before {
    background-color: rgba(255,255,255,0.03);
  }

  .blog-card:hover {
    background-color: transparent !important;
    transform: translateX(0.5rem);
    border-bottom-color: var(--text-color) !important;
  }

  .blog-card:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .card-titulo {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: normal;
    color: var(--text-color);
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
    text-transform: none;
    letter-spacing: -0.01em;
  }

  .blog-card:hover .card-titulo {
    color: var(--accent-color) !important;
  }

  .card-subtitulo {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--text-color);
    font-size: 1.1rem;
    margin: 0 0 0.5rem 0;
  }

  .card-excerpt {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--text-color);
    line-height: 1.6;
    margin: 0 0 1rem 0;
    max-width: 65ch;
  }

  .card-meta {
    font-family: var(--font-body) !important;
    font-size: 1.1rem !important;
    color: var(--meta-color) !important;
    margin: 0 !important;
    display: block !important;
    font-style: italic !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    font-weight: normal !important;
  }

  .card-meta span, .card-meta time {
    display: inline !important;
    font-family: var(--font-body) !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    font-weight: normal !important;
  }

  .card-meta::before {
    content: "— ";
  }

  .card-tipo {
    color: var(--text-color) !important;
  }

  .card-autor {
    color: var(--text-color) !important;
  }

  /* Do not invert colors on hover */
  .blog-card:hover .card-excerpt,
  .blog-card:hover .card-autor,
  .blog-card:hover time,
  .blog-card:hover .card-subtitulo,
  .blog-card:hover .card-meta {
    color: inherit;
  }
</style>






