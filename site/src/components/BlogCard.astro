---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  tipo: string;
  tipoLabel: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  data?: Date;
}

const {
  url,
  titulo,
  tipo,
  tipoLabel,
  subtitulo,
  autor,
  autorClasse,
  excerpt,
  data,
} = Astro.props;
---

<a href={url} class="blog-card" data-tipo={tipo} data-autor={autorClasse}>
  <h2 class="card-titulo">{titulo}</h2>
  {subtitulo && <p class="card-subtitulo">{subtitulo}</p>}
  <p class="card-excerpt">{excerpt}</p>
  <div class="card-meta">
    <span class="card-tipo">{tipoLabel}</span>
    {autor && <span class={`card-autor autor-${autorClasse}`}>/ {autor}</span>}
    {data && <time datetime={data.toISOString()}>/ {formatDate(data)}</time>}
  </div>
</a>

<style>
  .card-titulo {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    color: var(--text-color);
    line-height: 1.3;
    font-weight: 700;
  }

  .card-subtitulo {
    font-style: italic;
    color: var(--text-color);
    font-size: 0.95rem;
    margin: 0 0 0.5rem;
  }

  .card-excerpt {
    font-size: 0.92rem;
    color: var(--meta-color);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--meta-color);
  }

  .card-tipo {
    font-weight: 700;
    color: var(--text-color);
  }

  .card-autor {
    color: var(--meta-color);
  }
</style>
