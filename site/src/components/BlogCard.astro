---
import { formatDate } from "../lib/utils";

interface Props {
  url: string;
  titulo: string;
  tipo: string;
  tipoLabel: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  data?: Date;
}

const {
  url,
  titulo,
  tipo,
  tipoLabel,
  subtitulo,
  autor,
  autorClasse,
  excerpt,
  data,
} = Astro.props;
---

<a href={url} class="blog-card" data-tipo={tipo} data-autor={autorClasse}>
  <div class="card-meta">
    <span class="card-tipo">{tipoLabel}</span>
    {data && <time datetime={data.toISOString()}>{formatDate(data)}</time>}
    {autor && <span class={`card-autor autor-${autorClasse}`}>{autor}</span>}
  </div>
  <h2 class="card-titulo">{titulo}</h2>
  {subtitulo && <p class="card-subtitulo">{subtitulo}</p>}
  <p class="card-excerpt">{excerpt}</p>
</a>

<style>
  .card-titulo {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    color: var(--text-color);
    line-height: 1.3;
    font-weight: 700;
  }

  .card-subtitulo {
    font-style: italic;
    color: var(--text-color);
    font-size: 0.95rem;
    margin: 0 0 0.5rem;
  }

  .card-excerpt {
    font-size: 0.92rem;
    color: var(--meta-color);
    line-height: 1.55;
    margin: 0 0 0.75rem;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--meta-color);
  }

  .card-tipo {
    font-weight: 700;
    color: var(--text-color);
  }

  .card-autor {
    color: var(--meta-color);
  }

  /* Directory List Style */
  .blog-card {
    background-color: transparent !important;
    border: none !important;
    border-bottom: 1px solid var(--text-color) !important;
    border-radius: 0 !important;
    box-shadow: none !important;

    padding: 3rem 0 !important;
    margin-bottom: 0 !important;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    transform: none !important;
    transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease !important;
  }

  @media (min-width: 768px) {
    .blog-card {
      grid-template-columns: 2fr 3fr;
      align-items: baseline;
      gap: 3rem;
    }
  }

  :global([data-theme="dark"]) .blog-card {
    border-bottom: 1px solid var(--text-color) !important;
    box-shadow: none !important;
  }

  .blog-card:hover {
    transform: none !important;
    box-shadow: none !important;
    background-color: transparent !important;
    color: var(--text-color) !important;
    border-color: var(--text-color) !important;
    padding-left: 2rem !important;
    padding-right: 2rem !important;
    margin-left: -2rem !important;
    margin-right: -2rem !important;
  }



  :global([data-theme="dark"]) .blog-card:hover {
    background-color: transparent !important;
    color: var(--text-color) !important;
    box-shadow: none !important;
  }

  /* Maintain text colors during hover */
  .blog-card:hover .card-titulo,
  .blog-card:hover .card-excerpt,
  .blog-card:hover .card-autor,
  .blog-card:hover time,
  .blog-card:hover .card-subtitulo {
    color: var(--text-color) !important;
  }

  .blog-card .card-titulo {
    color: var(--text-color);
    font-family: var(--font-body);
    font-weight: normal;
    text-transform: none;
    letter-spacing: -0.04em;
    font-size: 2rem;
    line-height: 1.2;
    margin: 0;
  }

  .blog-card .card-excerpt {
    color: var(--text-color);
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.4;
    font-weight: 400;
    margin: 0;
  }

  .blog-card .card-tipo {
    color: var(--text-color);
    background-color: transparent;
    padding: 0;
    border: none;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    display: inline-block;
  }

  .blog-card:hover .card-tipo {
    background-color: transparent !important;
    color: var(--accent-color) !important;
    border-color: transparent !important;
    transform: scaleX(1.1);
    transform-origin: left;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .blog-card .card-meta {
    border-top: none !important;
    padding-top: 0;
    color: var(--meta-color);
    font-weight: 400;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }

  @media (min-width: 768px) {
    .blog-card .card-meta {
      grid-column: 1;
    }
    .blog-card .card-titulo,
    .blog-card .card-excerpt,
    .blog-card .card-subtitulo {
      grid-column: 2;
    }
  }

  .blog-card:hover .card-meta {
    border-top: none !important;
    color: var(--meta-color) !important;
    opacity: 1;
  }


  /* === Structural Brutalism: Typography & Spacing === */
  .blog-card {
    position: relative;
    overflow: visible;
  }

  .blog-card .card-titulo {
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), color 0.3s ease;
  }

  .blog-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 0;
    background-color: var(--accent-color);
    transition: height 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .blog-card:hover::before {
    height: 100%;
  }

  .blog-card:hover .card-titulo {
    font-style: italic;
    color: var(--text-color) !important;
    transform: translateX(1.5rem);
  }

  .blog-card .card-excerpt {
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .blog-card:hover .card-excerpt {
    transform: translateX(1.5rem);
  }

</style>
