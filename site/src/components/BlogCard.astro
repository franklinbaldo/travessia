---
import { formatDate } from "../lib/utils";
interface Props {
  url: string;
  titulo: string;
  tipo: string;
  tipoLabel: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  data?: Date;
}
const {
  url,
  titulo,
  tipo,
  tipoLabel,
  subtitulo,
  autor,
  autorClasse,
  excerpt,
  data,
} = Astro.props;
---
<a href={url} class="blog-card" data-tipo={tipo} data-autor={autorClasse}>
  <h2 class="card-titulo">{titulo}</h2>
  {subtitulo && <p class="card-subtitulo">{subtitulo}</p>}
  <p class="card-excerpt">{excerpt}</p>
  <div class="card-meta">
    <span class="card-tipo">{tipoLabel}</span>{data && <>, <time datetime={data.toISOString()}>{formatDate(data)}</time></>}{autor && <>. <span class={`card-autor autor-${autorClasse}`}>{autor}</span></>}
  </div>
</a>
<style>
  /* BRUTALIST BLOG CARD (Sessão 337 - Cor e Contraste) */
  .blog-card {
    display: block;
    text-decoration: none;
    padding: 2.5rem 2rem !important;
    margin-bottom: -4px !important; /* overlap thick borders */
    border: 1px solid var(--text-color) !important; /* Thick brutal borders */
    background-color: var(--bg-color) !important; /* Opaque solid blocks */
    box-shadow: none !important;
    position: relative;
    transition: none !important;
    z-index: 1;
  }
  .blog-card:hover {
    background-color: var(--brutal-hover-bg) !important;
    transform: translate(-6px, -6px); /* physical jump */
    box-shadow: 6px 6px 0 var(--text-color) !important; /* sharp shadow */
    z-index: 10;
  }
  .card-titulo {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 800; /* Bolder for brutalism */
    color: var(--text-color);
    margin: 0 0 0.5rem 0;
    line-height: 1.1;
    text-transform: uppercase; /* Index-like uppercase */
    letter-spacing: -0.01em;
  }
  /* On hover, text inverts inside the neon box */
  .blog-card:hover .card-titulo {
    color: var(--text-color) !important;
    background-color: transparent !important;
  }
  .card-subtitulo {
    font-family: var(--font-body);
    font-style: normal; /* remove italics */
    font-weight: bold;
    color: var(--text-color);
    font-size: 1.1rem;
    margin: 0 0 0.5rem 0;
    border-bottom: 2px solid var(--text-color); /* inline division */
    display: inline-block;
  }
  .card-excerpt {
    font-family: var(--font-meta); /* monospaced/meta font for raw data feel */
    font-size: 1rem;
    color: var(--text-color);
    line-height: 1.4;
    margin: 0 0 1rem 0;
    max-width: 100%;
  }
  .card-meta {
    font-family: var(--font-meta) !important;
    font-size: 0.9rem !important;
    color: var(--text-color) !important; /* High contrast black */
    margin: 0 !important;
    display: block !important;
    font-style: normal !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    font-weight: bold !important;
    border-top: 2px solid var(--text-color); /* Metadata separator */
    padding-top: 0.5rem;
  }
  .card-meta span, .card-meta time {
    display: inline !important;
    font-family: var(--font-meta) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    font-weight: bold !important;
  }
  .card-meta::before {
    content: "=> "; /* Code-like prompt */
  }
  .card-tipo {
    color: var(--accent-color) !important; /* Punchy red/magenta */
  }
  .blog-card:hover .card-tipo {
    color: var(--bg-color) !important;
  }
  .card-autor {
    color: var(--secondary-color) !important; /* Punchy blue/cyan */
  }
  .blog-card:hover .card-autor {
    color: var(--bg-color) !important;
  }
  /* Maintain black text inside the brutal hover bg */
  .blog-card:hover .card-excerpt,
  .blog-card:hover time,
  .blog-card:hover .card-subtitulo,
  .blog-card:hover .card-meta {
    color: var(--bg-color) !important;
  }
</style>
