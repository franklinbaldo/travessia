---
interface NavItem {
  url: string;
  title?: string;
  autor?: string;
  autorClasse?: string;
}
interface Props {
  prev?: NavItem;
  next?: NavItem;
  backUrl?: string;
  backLabel?: string;
}
const { prev, next, backUrl, backLabel } = Astro.props;
const isRich = !!(prev?.autor || next?.autor);
---
<nav class="footer-nav" aria-label="Navegação da postagem">
  {
    backUrl ? (
      <a href={backUrl}>&larr; {backLabel}</a>
    ) : (
      <>
        {prev ? (
          isRich ? (
            <a href={prev.url} class="footer-nav-link prev" rel="prev">
              <span class="footer-nav-dir">&larr; Anterior</span>
              {prev.autor && (
                <span class={`footer-nav-autor autor-${prev.autorClasse}`}>
                  {prev.autor}
                </span>
              )}
              {prev.title && (
                <span class="footer-nav-titulo">{prev.title}</span>
              )}
            </a>
          ) : (
            <a href={prev.url} title={prev.title} rel="prev">
              &larr; Anterior
            </a>
          )
        ) : (
          <span />
        )}
        {next ? (
          isRich ? (
            <a href={next.url} class="footer-nav-link next" rel="next">
              <span class="footer-nav-dir">Pr&oacute;ximo &rarr;</span>
              {next.autor && (
                <span class={`footer-nav-autor autor-${next.autorClasse}`}>
                  {next.autor}
                </span>
              )}
              {next.title && (
                <span class="footer-nav-titulo">{next.title}</span>
              )}
            </a>
          ) : (
            <a href={next.url} title={next.title} rel="next">
              Pr&oacute;ximo &rarr;
            </a>
          )
        ) : (
          <span />
        )}
      </>
    )
  }
</nav>
<style>
  .footer-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--meta-color);
  }
  .footer-nav a {
    font-size: 1rem;
    text-decoration: none;
  }
  /* Manuscript constraints: subtle, handwritten note aesthetic */
  .footer-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    max-width: 45%;
    flex: 1;
    padding: 1.5rem 1.5rem !important;
    background-color: transparent !important;
    border: none !important;
    border-radius: 0;
    box-shadow: none;
    text-decoration: none;
    transform: none;
    transition: none;
  }
  /* Microinteração de sublinhado estilo rabisco manual */
  .footer-nav-link::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 10%;
    width: 80%;
    height: 2px;
    background-color: var(--accent-color);
    border-radius: 0;
    transform: none;
    transform-origin: center;
    opacity: 0.7;
    transition: none;
  }
  /* Efeito de papel dobrado no hover */
  .footer-nav-link:hover {
    transform: none;
    background-color: transparent !important;
  }
  :global([data-theme="dark"]) .footer-nav-link:hover {
    background-color: transparent !important;
  }
  .footer-nav-link.next:hover {
    transform: none;
  }
  .footer-nav-link:hover::before {
    transform: none;
  }
  .footer-nav-link.next {
    text-align: right;
    align-items: flex-end;
    margin-left: auto;
  }
  .footer-nav-link.next::before {
    transform: none;
  }
  .footer-nav-link.next:hover::before {
    transform: none;
  }
  .footer-nav-dir {
    font-family: var(--font-meta);
    font-size: 0.8rem;
    text-transform: none;
    font-style: italic;
    letter-spacing: 0.02em;
    color: var(--meta-color);
    font-weight: normal;
  }
  .footer-nav-autor {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: normal;
    color: var(--text-color);
  }
  .footer-nav-titulo {
    font-family: var(--font-body);
    font-size: 1.25rem;
    color: var(--text-color);
    line-height: 1.3;
    font-weight: normal;
    font-style: italic;
  }
  .footer-nav-link:hover .footer-nav-titulo {
    color: var(--accent-color) !important;
  }
  @media (max-width: 600px) {
    .footer-nav {
      flex-direction: column;
      gap: 1.5rem;
    }
    .footer-nav-link {
      max-width: 100%;
      text-align: center;
      align-items: center;
    }
    .footer-nav-link.next {
      text-align: center;
      align-items: center;
    }
    .footer-nav-link::before {
      left: 20%;
      width: 60%;
    }
  }
</style>
