---
interface NavItem {
  url: string;
  title?: string;
  autor?: string;
  autorClasse?: string;
}
interface Props {
  prev?: NavItem;
  next?: NavItem;
  backUrl?: string;
  backLabel?: string;
}
const { prev, next, backUrl, backLabel } = Astro.props;
const isRich = !!(prev?.autor || next?.autor);
---
<nav class="footer-nav" aria-label="Navegação da postagem">
  {
    backUrl ? (
      <a href={backUrl} class="footer-nav-link back">
        <span aria-hidden="true">&larr;</span> {backLabel}
      </a>
    ) : (
      <>
        {prev ? (
          isRich ? (
            <a href={prev.url} class="footer-nav-link prev" rel="prev">
              <span class="footer-nav-dir">
                <span aria-hidden="true">&larr;</span> Anterior
              </span>
              {prev.autor && (
                <span class={`footer-nav-autor autor-${prev.autorClasse}`}>
                  {prev.autor}
                </span>
              )}
              {prev.title && (
                <span class="footer-nav-titulo">{prev.title}</span>
              )}
            </a>
          ) : (
            <a href={prev.url} class="footer-nav-link prev" title={prev.title} rel="prev">
              <span aria-hidden="true">&larr;</span> Anterior
            </a>
          )
        ) : (
          <span />
        )}
        {next ? (
          isRich ? (
            <a href={next.url} class="footer-nav-link next" rel="next">
              <span class="footer-nav-dir">
                Pr&oacute;ximo <span aria-hidden="true">&rarr;</span>
              </span>
              {next.autor && (
                <span class={`footer-nav-autor autor-${next.autorClasse}`}>
                  {next.autor}
                </span>
              )}
              {next.title && (
                <span class="footer-nav-titulo">{next.title}</span>
              )}
            </a>
          ) : (
            <a href={next.url} class="footer-nav-link next" title={next.title} rel="next">
              Pr&oacute;ximo <span aria-hidden="true">&rarr;</span>
            </a>
          )
        ) : (
          <span />
        )}
      </>
    )
  }
</nav>
<style>
  .footer-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 4px solid var(--text-color);
  }
  .footer-nav a {
    font-size: 1rem;
    text-decoration: none;
  }
  /* Manuscript constraints: subtle, handwritten note aesthetic */
  .footer-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    max-width: 45%;
    flex: 1;
    padding: 2rem 2rem !important;
    background-color: var(--bg-color) !important;
    border: 4px solid var(--text-color) !important;
    border-radius: 0;
    box-shadow: none;
    text-decoration: none;
    transform: none;
    transition: none;
  }
  /* Efeito de papel dobrado no hover */
  .footer-nav-link:hover {
    transform: translate(-6px, -6px) !important;
    background-color: var(--brutal-hover-bg) !important;
    box-shadow: 6px 6px 0px 0px var(--text-color) !important;
    border-color: var(--text-color) !important;
  }
  :global([data-theme="dark"]) .footer-nav-link:hover {
    background-color: var(--brutal-hover-bg) !important;
    color: var(--bg-color) !important;
  }
  .footer-nav-link.next:hover {
    transform: translate(-6px, -6px) !important;
  }
  .footer-nav-link.next {
    text-align: right;
    align-items: flex-end;
    margin-left: auto;
  }
  .footer-nav-dir {
    font-family: var(--font-meta);
    font-size: 1rem;
    text-transform: uppercase;
    font-style: normal;
    font-weight: bold;
    letter-spacing: 0.05em;
    color: var(--text-color);
  }
  .footer-nav-autor {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: normal;
    color: var(--text-color);
  }
  .footer-nav-titulo {
    font-family: var(--font-body);
    font-size: 1.4rem;
    color: var(--text-color);
    line-height: 1.3;
    font-weight: bold;
    font-style: italic;
  }
  .footer-nav-link:hover .footer-nav-titulo,
  .footer-nav-link:hover .footer-nav-dir,
  .footer-nav-link:hover .footer-nav-autor {
    color: var(--text-color) !important;
  }
  @media (max-width: 600px) {
    .footer-nav {
      flex-direction: column;
      gap: 1.5rem;
    }
    .footer-nav-link {
      max-width: 100%;
      text-align: center;
      align-items: center;
    }
    .footer-nav-link.next {
      text-align: center;
      align-items: center;
    }
  }
</style>
