---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import { getExcerpt, getFileNum, slugToLabel } from '../lib/utils';

const base = import.meta.env.BASE_URL;

// Load all collections
const allDialogo = await getCollection('dialogo');
const allManuscrito = await getCollection('manuscrito');
const allCartasDoutorJoao = await getCollection('cartas-doutor-joao');
const allCartasZeBebelo = await getCollection('cartas-ze-bebelo');
const allDialogoTedTyler = await getCollection('dialogo-ted-tyler');
const allBastidoresRiobaldo = await getCollection('bastidores-riobaldo');
const allBastidoresTed = await getCollection('bastidores-ted');
// Craig journals have inconsistent frontmatter; skipped for now
// const allBastidoresCraig = await getCollection('bastidores-craig');

// Non-content files to exclude from bastidores
const excludeFiles = new Set(['PROMPT', 'EXPERIENCE', 'GLOSSARIO']);

interface BlogPost {
  slug: string;
  titulo: string;
  tipo: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  longExcerpt?: string;
  url: string;
  data?: Date;
  ordem: number;
}

const posts: BlogPost[] = [];

// Cartas Ted-Riobaldo (diálogo principal)
for (const entry of allDialogo) {
  const isRio = entry.data.autor.includes('Riobaldo');
  const fileNum = getFileNum(entry.id);

  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: 'carta',
    autor: entry.data.autor,
    autorClasse: isRio ? 'rio' : 'ted',
    excerpt: getExcerpt(entry.body),
    longExcerpt: getExcerpt(entry.body, 320),
    url: `${base}carta/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Manuscritos
for (const entry of allManuscrito) {
  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: entry.data.tipo,
    subtitulo: entry.data.subtitulo,
    excerpt: getExcerpt(entry.body),
    url: `${base}texto/${entry.id}`,
    ordem: entry.data.ordem || 999,
  });
}

// Cartas a Doutor João
for (const entry of allCartasDoutorJoao) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Carta a ${entry.data.destinatario || 'Doutor João'}`,
    tipo: 'carta-pessoal',
    autor: 'Riobaldo Tatarana',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}carta-pessoal/cartas-doutor-joao/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Cartas a Zé Bebelo
for (const entry of allCartasZeBebelo) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Carta a ${entry.data.destinatario || 'Zé Bebelo'}`,
    tipo: 'carta-pessoal',
    autor: 'Riobaldo Tatarana',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}carta-pessoal/cartas-ze-bebelo/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Diálogo Ted-Tyler
for (const entry of allDialogoTedTyler) {
  const isTyler = entry.data.autor.includes('Tyler');
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: 'carta-ted-tyler',
    autor: entry.data.autor,
    autorClasse: isTyler ? 'tyler' : 'ted',
    excerpt: getExcerpt(entry.body),
    url: `${base}dialogo-ted-tyler/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Bastidores Riobaldo (journals, fitas, pensamentos, cartas pessoais, rascunhos)
for (const entry of allBastidoresRiobaldo) {
  const baseName = entry.id.split('/').pop() || entry.id;
  const nameWithoutExt = baseName.replace(/\.md$/, '');
  if (excludeFiles.has(nameWithoutExt) || excludeFiles.has(baseName)) continue;

  const fileNum = getFileNum(baseName);
  const isFita = entry.data.tipo === 'transcricao' || entry.id.includes('fitas/');
  const isCarta = entry.id.includes('cartas/');
  const isPensamento = entry.id.includes('pensamento');
  const isRascunho = entry.id.includes('rascunhos/');

  let tipo = 'journal-rio';
  let titulo = `Riobaldo — ${slugToLabel(baseName)}`;

  if (isFita) {
    tipo = 'fita';
    titulo = `Fita ${fileNum}`;
  } else if (isCarta) {
    tipo = 'carta-pessoal';
    titulo = `Carta a ${entry.data.destinatario || 'desconhecido'}`;
  } else if (isPensamento) {
    tipo = 'pensamento';
    titulo = `Pensamento — sessão ${fileNum}`;
  } else if (isRascunho) {
    tipo = 'rascunho';
    titulo = `Rascunho — sessão ${fileNum}`;
  }

  posts.push({
    slug: entry.id,
    titulo,
    tipo,
    autor: 'Riobaldo',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}bastidores/riobaldo/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Bastidores Ted (journals)
for (const entry of allBastidoresTed) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Ted — journal ${fileNum}`,
    tipo: 'journal-ted',
    autor: 'Ted Chiang',
    autorClasse: 'ted',
    excerpt: getExcerpt(entry.body),
    url: `${base}bastidores/ted/${entry.id}`,
    ordem: 1e6 + fileNum,
  });
}

// Craig journals have inconsistent frontmatter; skipped for now

// Sort: by date descending where available, then by ordem descending
posts.sort((a, b) => {
  if (a.data && b.data) return b.data.getTime() - a.data.getTime();
  if (a.data && !b.data) return -1;
  if (!a.data && b.data) return 1;
  return b.ordem - a.ordem;
});

// Featured post: most recent carta ted-riobaldo
const featuredPost = posts.find(p => p.tipo === 'carta');
const gridPosts = posts.filter(p => p !== featuredPost);

// Build tipo labels and categories
const tipoLabels: Record<string, string> = {
  todos: 'Tudo',
  carta: 'Cartas Ted-Riobaldo',
  'carta-pessoal': 'Cartas Pessoais',
  'carta-ted-tyler': 'Cartas Ted-Tyler',
  fita: 'Fitas',
  pensamento: 'Pensamentos',
  rascunho: 'Rascunhos',
  'journal-rio': 'Journals Riobaldo',
  'journal-ted': 'Journals Ted',
  'journal-craig': 'Journals Craig',
  abertura: 'Abertura',
  causo: 'Causos',
  fechamento: 'Fechamento',
  fragmento: 'Fragmentos',
};

const tiposSet = new Set(gridPosts.map(p => p.tipo));
const tipos = ['todos', ...Array.from(tiposSet)];
---

<Layout title="Travessia" isHome={true}>

  <!-- Hero Section — Split Layout -->
  <section class="blog-hero">
    <div class="hero-typographic">
      <div class="hero-text-col">
        <h1>Travessia</h1>
        <p class="hero-quote">"O diabo não há! É o homem humano. Travessia."</p>
        <p class="hero-sub">Dois homens que nunca se encontraram trocam cartas sobre o que não tem nome.</p>
        <div class="hero-characters">
          <span class="character-badge badge-riobaldo">Riobaldo Tatarana</span>
          <span class="character-badge badge-ted">Ted Chiang</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Post — Última Carta -->
  {featuredPost && (
    <FeaturedPost
      url={featuredPost.url}
      titulo={featuredPost.titulo}
      autorClasse={featuredPost.autorClasse}
      autor={featuredPost.autor}
      excerpt={featuredPost.longExcerpt || featuredPost.excerpt}
      data={featuredPost.data}
    />
  )}

  <!-- Veredas — Category Navigation -->
  {tipos.length > 2 && (
    <nav class="veredas" aria-label="Categorias">
      {tipos.map((tipo) => (
        <button
          class={`vereda ${tipo === 'todos' ? 'active' : ''}`}
          data-filter={tipo}
          aria-pressed={tipo === 'todos' ? 'true' : 'false'}
        >
          {tipoLabels[tipo] || tipo}
        </button>
      ))}
    </nav>
  )}

  <!-- Blog Feed — O Fluxo Contínuo -->
  {gridPosts.length === 0 ? (
    <p class="silencio">O sertão ainda está em silêncio.</p>
  ) : (
    <div class="blog-feed">
      {gridPosts.map((post) => (
        <BlogCard
          url={post.url}
          titulo={post.titulo}
          tipo={post.tipo}
          tipoLabel={tipoLabels[post.tipo] || post.tipo}
          subtitulo={post.subtitulo}
          autor={post.autor}
          autorClasse={post.autorClasse}
          excerpt={post.excerpt}
          data={post.data}
        />
      ))}
    </div>
  )}

  <!-- Category filter -->
  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.vereda');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        buttons.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        document.querySelectorAll<HTMLElement>('[data-tipo]').forEach((card) => {
          card.style.display =
            filter === 'todos' || card.getAttribute('data-tipo') === filter ? '' : 'none';
        });
      });
    });
  </script>

</Layout>

<style>
  /* Hero — Split Layout */
  .blog-hero {
    margin-bottom: 2.5rem;
  }

  .hero-typographic {
    display: block;
    margin: 0 -2rem 0;
    border: 4px solid var(--text-color);
    background: var(--bg-color);
    text-align: center;
  }

  .hero-text-col {
    padding: 6rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
  }

  .blog-hero h1 {
    font-size: clamp(4rem, 15vw, 10rem);
    margin: 0;
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: var(--accent-color);
    text-transform: uppercase;
    border-bottom: none;
  }

  .hero-quote {
    font-style: italic;
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: var(--text-color);
    margin: 0;
    line-height: 1.3;
    font-weight: 600;
  }

  .hero-sub {
    font-family: var(--font-meta);
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    color: var(--meta-color);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0;
    max-width: 600px;
    line-height: 1.6;
  }

  .hero-characters {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .character-badge {
    display: inline-block;
    padding: 0.3rem 0.9rem; border: 2px solid var(--text-color);
    letter-spacing: 0.1em;
    font-family: var(--font-meta);
    font-size: 0.62rem;
    text-transform: uppercase; border-radius: 0;
    background: var(--sand-bg);
  }

  .badge-riobaldo {
    color: var(--secondary-color);
  }

  .badge-ted {
    color: #5a908b;
  }

  :global([data-theme="dark"]) .badge-ted {
    color: #7ab5b0;
  }

  @media (max-width: 700px) {
    .hero-typographic {
      margin: 0 -1rem 0;
      border-width: 2px;
    }

    .hero-text-col {
      padding: 3rem 1rem;
      gap: 1rem;
    }
  }

  /* Veredas — Category Navigation */
  .veredas {
    display: flex;
    gap: 0.6rem;
    overflow-x: auto;
    padding: 0;
    margin-bottom: 3rem; border-bottom: 2px solid var(--text-color); border-top: 2px solid var(--text-color);
    scrollbar-width: none;
    -ms-overflow-style: none;
    justify-content: center;
    flex-wrap: wrap;
  }

  .veredas::-webkit-scrollbar {
    display: none;
  }

  .vereda {
    background: none; border: 2px solid var(--text-color);
    color: var(--meta-color);
    font-family: var(--font-meta);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.9rem; border-radius: 0;
    margin-bottom: -2px; border-bottom: 2px solid var(--text-color);
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease;
  }

  .vereda:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
  }

  .vereda:global(.active) {
    background: var(--bg-color);
    border-color: var(--divider-color);
    border-bottom-color: var(--bg-color); border-top: 2px solid var(--text-color);
    color: var(--text-color);
  }

  /* Blog Feed Grid */
  .blog-feed {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
  }

  @media (max-width: 700px) {
    .blog-feed {
      grid-template-columns: 1fr;
    }
  }


  /* Split Screen Layout for Desktop */
  @media (min-width: 900px) {
    :global(main.home-layout) {
      max-width: 1400px !important;
      display: grid;
      grid-template-columns: 450px 1fr;
      grid-template-areas:
        "nav nav"
        "hero featured"
        "hero veredas"
        "hero feed";
      gap: 2rem 5rem;
      align-items: start;
      padding-left: 0;
      padding-right: 0;
    }

    :global(main.home-layout > nav) {
      grid-area: nav;
      margin-bottom: 2rem;
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .blog-hero {
      grid-area: hero;
      position: sticky;
      top: 0;
      margin-bottom: 0 !important;
      height: 100vh;
      overflow-y: auto;
      scrollbar-width: none;
      /* Remove border right */
      border-right: 2px dashed var(--text-color);
    }
    .blog-hero::-webkit-scrollbar {
      display: none;
    }

    .hero-typographic {
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      margin: 0 !important;
      border: none;
      background: transparent;
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .blog-hero h1 {
        font-size: clamp(5rem, 10vw, 8rem);
        text-align: left;
    }

    .hero-quote, .hero-sub, .hero-characters {
        text-align: left;
        align-items: flex-start;
        justify-content: flex-start;
    }

    :global(.featured-post) {
      grid-area: featured;
      margin-bottom: 0 !important;
      margin-right: 2rem;
    }

    .veredas {
      grid-area: veredas;
      margin-bottom: 0 !important;
      justify-content: flex-start;
    }

    .blog-feed {
      grid-area: feed;
      padding-bottom: 4rem;
      margin-right: 2rem;
    }
  }
</style>
