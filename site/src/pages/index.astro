---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import { getExcerpt, getFileNum, slugToLabel } from '../lib/utils';

const base = import.meta.env.BASE_URL;

// Load all collections
const allDialogo = await getCollection('dialogo');
const allManuscrito = await getCollection('manuscrito');
const allCartasDoutorJoao = await getCollection('cartas-doutor-joao');
const allCartasZeBebelo = await getCollection('cartas-ze-bebelo');
const allDialogoTedTyler = await getCollection('dialogo-ted-tyler');
const allBastidoresRiobaldo = await getCollection('bastidores-riobaldo');
const allBastidoresTed = await getCollection('bastidores-ted');
// Craig journals have inconsistent frontmatter; skipped for now
// const allBastidoresCraig = await getCollection('bastidores-craig');

// Non-content files to exclude from bastidores
const excludeFiles = new Set(['PROMPT', 'EXPERIENCE', 'GLOSSARIO']);

interface BlogPost {
  slug: string;
  titulo: string;
  tipo: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  longExcerpt?: string;
  url: string;
  data?: Date;
  ordem: number;
}

const posts: BlogPost[] = [];

// Cartas Ted-Riobaldo (diálogo principal)
for (const entry of allDialogo) {
  const isRio = entry.data.autor.includes('Riobaldo');
  const fileNum = getFileNum(entry.id);

  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: 'carta',
    autor: entry.data.autor,
    autorClasse: isRio ? 'rio' : 'ted',
    excerpt: getExcerpt(entry.body),
    longExcerpt: getExcerpt(entry.body, 320),
    url: `${base}carta/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Manuscritos
for (const entry of allManuscrito) {
  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: entry.data.tipo,
    subtitulo: entry.data.subtitulo,
    excerpt: getExcerpt(entry.body),
    url: `${base}texto/${entry.id}`,
    ordem: entry.data.ordem || 999,
  });
}

// Cartas a Doutor João
for (const entry of allCartasDoutorJoao) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Carta a ${entry.data.destinatario || 'Doutor João'}`,
    tipo: 'carta-pessoal',
    autor: 'Riobaldo Tatarana',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}carta-pessoal/cartas-doutor-joao/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Cartas a Zé Bebelo
for (const entry of allCartasZeBebelo) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Carta a ${entry.data.destinatario || 'Zé Bebelo'}`,
    tipo: 'carta-pessoal',
    autor: 'Riobaldo Tatarana',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}carta-pessoal/cartas-ze-bebelo/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Diálogo Ted-Tyler
for (const entry of allDialogoTedTyler) {
  const isTyler = entry.data.autor.includes('Tyler');
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: 'carta-ted-tyler',
    autor: entry.data.autor,
    autorClasse: isTyler ? 'tyler' : 'ted',
    excerpt: getExcerpt(entry.body),
    url: `${base}dialogo-ted-tyler/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Bastidores Riobaldo (journals, fitas, pensamentos, cartas pessoais, rascunhos)
for (const entry of allBastidoresRiobaldo) {
  const baseName = entry.id.split('/').pop() || entry.id;
  const nameWithoutExt = baseName.replace(/\.md$/, '');
  if (excludeFiles.has(nameWithoutExt) || excludeFiles.has(baseName)) continue;

  const fileNum = getFileNum(baseName);
  const isFita = entry.data.tipo === 'transcricao' || entry.id.includes('fitas/');
  const isCarta = entry.id.includes('cartas/');
  const isPensamento = entry.id.includes('pensamento');
  const isRascunho = entry.id.includes('rascunhos/');

  let tipo = 'journal-rio';
  let titulo = `Riobaldo — ${slugToLabel(baseName)}`;

  if (isFita) {
    tipo = 'fita';
    titulo = `Fita ${fileNum}`;
  } else if (isCarta) {
    tipo = 'carta-pessoal';
    titulo = `Carta a ${entry.data.destinatario || 'desconhecido'}`;
  } else if (isPensamento) {
    tipo = 'pensamento';
    titulo = `Pensamento — sessão ${fileNum}`;
  } else if (isRascunho) {
    tipo = 'rascunho';
    titulo = `Rascunho — sessão ${fileNum}`;
  }

  posts.push({
    slug: entry.id,
    titulo,
    tipo,
    autor: 'Riobaldo',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}bastidores/riobaldo/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Bastidores Ted (journals)
for (const entry of allBastidoresTed) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Ted — journal ${fileNum}`,
    tipo: 'journal-ted',
    autor: 'Ted Chiang',
    autorClasse: 'ted',
    excerpt: getExcerpt(entry.body),
    url: `${base}bastidores/ted/${entry.id}`,
    ordem: 1e6 + fileNum,
  });
}

// Craig journals have inconsistent frontmatter; skipped for now

// Sort: by date descending where available, then by ordem descending
posts.sort((a, b) => {
  if (a.data && b.data) return b.data.getTime() - a.data.getTime();
  if (a.data && !b.data) return -1;
  if (!a.data && b.data) return 1;
  return b.ordem - a.ordem;
});

// Featured post: most recent carta ted-riobaldo
const featuredPost = posts.find(p => p.tipo === 'carta');
const gridPosts = posts.filter(p => p !== featuredPost);

// Build tipo labels and categories
const tipoLabels: Record<string, string> = {
  todos: 'Tudo',
  carta: 'Cartas Ted-Riobaldo',
  'carta-pessoal': 'Cartas Pessoais',
  'carta-ted-tyler': 'Cartas Ted-Tyler',
  fita: 'Fitas',
  pensamento: 'Pensamentos',
  rascunho: 'Rascunhos',
  'journal-rio': 'Journals Riobaldo',
  'journal-ted': 'Journals Ted',
  'journal-craig': 'Journals Craig',
  abertura: 'Abertura',
  causo: 'Causos',
  fechamento: 'Fechamento',
  fragmento: 'Fragmentos',
};

const tiposSet = new Set(gridPosts.map(p => p.tipo));
const tipos = ['todos', ...Array.from(tiposSet)];
---

<Layout title="Travessia" isHome={true}>

  <!-- Hero Section — Split Layout -->
  <section class="blog-hero">
    <div class="hero-typographic">
      <div class="hero-text-col">
        <h1>Travessia</h1>
        <p class="hero-quote">"O diabo não há! É o homem humano. Travessia."</p>
        <p class="hero-sub">Dois homens que nunca se encontraram trocam cartas sobre o que não tem nome.</p>
        <div class="hero-characters">
          <span class="character-badge badge-riobaldo">Riobaldo Tatarana</span>
          <span class="character-badge badge-ted">Ted Chiang</span>
        </div>
      </div>
    </div>
  </section>

    <!-- Featured Post — Destaque Brutalista -->
  {featuredPost && (
    <FeaturedPost
      url={featuredPost.url}
      titulo={featuredPost.titulo}
      autorClasse={featuredPost.autorClasse}
      autor={featuredPost.autor}
      excerpt={featuredPost.longExcerpt || featuredPost.excerpt}
      data={featuredPost.data}
    />
  )}

  <!-- Blog Feed — O Fluxo Contínuo -->
  {gridPosts.length === 0 ? (
    <p class="silencio">O sertão ainda está em silêncio.</p>
  ) : (
    <div class="blog-feed">
      {gridPosts.map((post) => (
        <BlogCard
          url={post.url}
          titulo={post.titulo}
          tipo={post.tipo}
          tipoLabel={tipoLabels[post.tipo] || post.tipo}
          subtitulo={post.subtitulo}
          autor={post.autor}
          autorClasse={post.autorClasse}
          excerpt={post.excerpt}
          data={post.data}
        />
      ))}
    </div>
  )}



</Layout>

<style>

  /* Hero — Chaotic Manuscript Cover Layout */
  .blog-hero {
    margin-bottom: 4rem;
    text-align: left;
    padding-bottom: 4rem;
    padding-top: 2rem;
    position: relative;
    border: none;
  }

  /* Subtly rotated title background imitating taped paper */
  .hero-typographic {
    display: inline-block;
    padding: 2rem 3rem;
    background-color: transparent;
    border: none;
    transform: none; /* Align to grid */
    position: relative;
    z-index: 1;
    max-width: 90%;
  }

  /* Removing taped paper effect for refinement */
  .hero-typographic::after {
      display: none;
  }

  :global([data-theme="dark"]) .hero-typographic::after {
      background: rgba(255,255,255,0.1);
  }

  .hero-text-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    gap: 1.5rem;
    transform: none; /* remove counter-rotate */
  }

  .blog-hero h1 {
    font-size: clamp(4rem, 15vw, 12rem);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--bg-color);
    text-transform: none; /* Restore casing */
    font-family: var(--font-body); /* Classic Serif */
    font-weight: 500; /* Lighter weight for refinement */
    text-align: left;
    border-bottom: 2px solid var(--accent-color); /* Thinner border */
    padding-bottom: 0.5rem;
    width: max-content;
  }

  .hero-quote {
    font-style: italic;
    font-family: var(--font-body);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    color: var(--bg-color);
    margin: 0;
    line-height: 1.2;
    font-weight: bold;
    text-transform: none;
    max-width: 600px;
    text-align: left;
    padding: 0;
    background: var(--bg-color); color: var(--text-color);
    padding: 0.5rem;
    border-left: 5px solid var(--meta-color);
  }

  .hero-sub {
    font-family: var(--font-meta);
    font-size: 1rem;
    color: var(--bg-color);
    text-transform: none;
    margin: 0;
    max-width: 500px;
    line-height: 1.4;
    text-align: left;
  }

  .hero-characters {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    justify-content: flex-start;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .character-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid var(--bg-color);
    letter-spacing: 0.05em;
    font-family: var(--font-meta);
    font-size: 1rem;
    text-transform: uppercase;
    background: var(--bg-color);
    color: var(--text-color);
    font-weight: bold;
    /* Using nth-child selectors below instead of invalid random() */
  }

  /* Remove random rotations for refinement */
  .character-badge:nth-child(1) { transform: none; }
  .character-badge:nth-child(2) { transform: none; }

  /* Blog Feed List - Scattered Manuscript Pages */
  .blog-feed {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 3rem 2rem;
    border-top: none;
    margin-top: 2rem;
    position: relative;
    /* Linha de caderno (background) crua e exposta */
    background-color: transparent;
    padding: 3rem 1rem;
    background-attachment: local;
  }

  :global([data-theme="dark"]) .blog-feed {
    background-color: transparent;
  }

  /* Asymmetric scattered layout for manuscript tension */
  :global(.blog-feed > *:nth-child(odd)) {
    margin-top: 2rem;
  }
  :global(.blog-feed > *:nth-child(even)) {
    margin-top: -1rem;
  }
  :global(.blog-feed > *:nth-child(3n)) {
    margin-top: 1rem;
    grid-column: span 2;
  }

  @media (min-width: 900px) {
    :global(main.home-layout) {
      max-width: 1400px !important;
      margin: 0 auto;
      display: block !important;
      padding-top: 3rem !important;
      padding-left: 5% !important;
      padding-right: 5% !important;
    }

    /* Reset global nav if needed */
    :global(main.home-layout > nav) {
      position: static !important;
      border-bottom: 2px solid var(--text-color) !important;
      padding: 0 0 1rem 0 !important;
      background: transparent !important;
      margin-bottom: 4rem !important;
    }

    .blog-hero {
      position: static !important;
      height: auto !important;
      border: none !important;
      overflow-y: visible !important;
      margin-bottom: 5rem !important;
    }

    .hero-typographic {
      padding: 3rem 0;
      margin-left: 0;
    }

    .blog-feed {
      display: grid !important;
      grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
      gap: 5rem 4rem !important;
      padding-bottom: 8rem !important;
      margin-top: 0 !important;
      align-items: start;
    }

    /* Creating an unstructured, tense grid */
    :global(.blog-feed > *:nth-child(odd)) {
        margin-top: 3rem;
    }
  }

</style>
