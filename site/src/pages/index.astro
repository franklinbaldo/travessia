---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import { getExcerpt, getFileNum, slugToLabel } from '../lib/utils';

const base = import.meta.env.BASE_URL;

// Load all collections
const allDialogo = await getCollection('dialogo');
const allManuscrito = await getCollection('manuscrito');
const allCartasDoutorJoao = await getCollection('cartas-doutor-joao');
const allCartasZeBebelo = await getCollection('cartas-ze-bebelo');
const allDialogoTedTyler = await getCollection('dialogo-ted-tyler');
const allBastidoresRiobaldo = await getCollection('bastidores-riobaldo');
const allBastidoresTed = await getCollection('bastidores-ted');
// Craig journals have inconsistent frontmatter; skipped for now
// const allBastidoresCraig = await getCollection('bastidores-craig');

// Non-content files to exclude from bastidores
const excludeFiles = new Set(['PROMPT', 'EXPERIENCE', 'GLOSSARIO']);

interface BlogPost {
  slug: string;
  titulo: string;
  tipo: string;
  subtitulo?: string;
  autor?: string;
  autorClasse?: string;
  excerpt: string;
  longExcerpt?: string;
  url: string;
  data?: Date;
  ordem: number;
}

const posts: BlogPost[] = [];

// Cartas Ted-Riobaldo (diálogo principal)
for (const entry of allDialogo) {
  const isRio = entry.data.autor.includes('Riobaldo');
  const fileNum = getFileNum(entry.id);

  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: 'carta',
    autor: entry.data.autor,
    autorClasse: isRio ? 'rio' : 'ted',
    excerpt: getExcerpt(entry.body),
    longExcerpt: getExcerpt(entry.body, 320),
    url: `${base}carta/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Manuscritos
for (const entry of allManuscrito) {
  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: entry.data.tipo,
    subtitulo: entry.data.subtitulo,
    excerpt: getExcerpt(entry.body),
    url: `${base}texto/${entry.id}`,
    ordem: entry.data.ordem || 999,
  });
}

// Cartas a Doutor João
for (const entry of allCartasDoutorJoao) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Carta a ${entry.data.destinatario || 'Doutor João'}`,
    tipo: 'carta-pessoal',
    autor: 'Riobaldo Tatarana',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}carta-pessoal/cartas-doutor-joao/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Cartas a Zé Bebelo
for (const entry of allCartasZeBebelo) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Carta a ${entry.data.destinatario || 'Zé Bebelo'}`,
    tipo: 'carta-pessoal',
    autor: 'Riobaldo Tatarana',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}carta-pessoal/cartas-ze-bebelo/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Diálogo Ted-Tyler
for (const entry of allDialogoTedTyler) {
  const isTyler = entry.data.autor.includes('Tyler');
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: entry.data.titulo,
    tipo: 'carta-ted-tyler',
    autor: entry.data.autor,
    autorClasse: isTyler ? 'tyler' : 'ted',
    excerpt: getExcerpt(entry.body),
    url: `${base}dialogo-ted-tyler/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Bastidores Riobaldo (journals, fitas, pensamentos, cartas pessoais, rascunhos)
for (const entry of allBastidoresRiobaldo) {
  const baseName = entry.id.split('/').pop() || entry.id;
  const nameWithoutExt = baseName.replace(/\.md$/, '');
  if (excludeFiles.has(nameWithoutExt) || excludeFiles.has(baseName)) continue;

  const fileNum = getFileNum(baseName);
  const isFita = entry.data.tipo === 'transcricao' || entry.id.includes('fitas/');
  const isCarta = entry.id.includes('cartas/');
  const isPensamento = entry.id.includes('pensamento');
  const isRascunho = entry.id.includes('rascunhos/');

  let tipo = 'journal-rio';
  let titulo = `Riobaldo — ${slugToLabel(baseName)}`;

  if (isFita) {
    tipo = 'fita';
    titulo = `Fita ${fileNum}`;
  } else if (isCarta) {
    tipo = 'carta-pessoal';
    titulo = `Carta a ${entry.data.destinatario || 'desconhecido'}`;
  } else if (isPensamento) {
    tipo = 'pensamento';
    titulo = `Pensamento — sessão ${fileNum}`;
  } else if (isRascunho) {
    tipo = 'rascunho';
    titulo = `Rascunho — sessão ${fileNum}`;
  }

  posts.push({
    slug: entry.id,
    titulo,
    tipo,
    autor: 'Riobaldo',
    autorClasse: 'rio',
    excerpt: getExcerpt(entry.body),
    url: `${base}bastidores/riobaldo/${entry.id}`,
    data: entry.data.data ? new Date(entry.data.data) : undefined,
    ordem: 1e6 + fileNum,
  });
}

// Bastidores Ted (journals)
for (const entry of allBastidoresTed) {
  const fileNum = getFileNum(entry.id);
  posts.push({
    slug: entry.id,
    titulo: `Ted — journal ${fileNum}`,
    tipo: 'journal-ted',
    autor: 'Ted Chiang',
    autorClasse: 'ted',
    excerpt: getExcerpt(entry.body),
    url: `${base}bastidores/ted/${entry.id}`,
    ordem: 1e6 + fileNum,
  });
}

// Craig journals have inconsistent frontmatter; skipped for now

// Sort: by date descending where available, then by ordem descending
posts.sort((a, b) => {
  if (a.data && b.data) return b.data.getTime() - a.data.getTime();
  if (a.data && !b.data) return -1;
  if (!a.data && b.data) return 1;
  return b.ordem - a.ordem;
});

// Featured post: most recent carta ted-riobaldo
const featuredPost = posts.find(p => p.tipo === 'carta');
const gridPosts = posts.filter(p => p !== featuredPost);

// Build tipo labels and categories
const tipoLabels: Record<string, string> = {
  todos: 'Tudo',
  carta: 'Cartas Ted-Riobaldo',
  'carta-pessoal': 'Cartas Pessoais',
  'carta-ted-tyler': 'Cartas Ted-Tyler',
  fita: 'Fitas',
  pensamento: 'Pensamentos',
  rascunho: 'Rascunhos',
  'journal-rio': 'Journals Riobaldo',
  'journal-ted': 'Journals Ted',
  'journal-craig': 'Journals Craig',
  abertura: 'Abertura',
  causo: 'Causos',
  fechamento: 'Fechamento',
  fragmento: 'Fragmentos',
};

const tiposSet = new Set(gridPosts.map(p => p.tipo));
const tipos = ['todos', ...Array.from(tiposSet)];
---

<Layout title="Travessia" isHome={true}>

  <!-- Hero Section — Split Layout -->
  <section class="blog-hero">
    <div class="hero-typographic">
      <div class="hero-text-col">
        <h1>Travessia</h1>
        <p class="hero-quote">"O diabo não há! É o homem humano. Travessia."</p>
        <p class="hero-sub">Dois homens que nunca se encontraram trocam cartas sobre o que não tem nome.</p>
        <div class="hero-characters">
          <span class="character-badge badge-riobaldo">Riobaldo Tatarana</span>
          <span class="character-badge badge-ted">Ted Chiang</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Post removed for performance -->

  <!-- Blog Feed — O Fluxo Contínuo -->
  {gridPosts.length === 0 ? (
    <p class="silencio">O sertão ainda está em silêncio.</p>
  ) : (
    <div class="blog-feed">
      {gridPosts.map((post) => (
        <BlogCard
          url={post.url}
          titulo={post.titulo}
          tipo={post.tipo}
          tipoLabel={tipoLabels[post.tipo] || post.tipo}
          subtitulo={post.subtitulo}
          autor={post.autor}
          autorClasse={post.autorClasse}
          excerpt={post.excerpt}
          data={post.data}
        />
      ))}
    </div>
  )}



</Layout>

<style>
  /* Hero — Broadsheet Masthead Layout */
  .blog-hero {
    margin-bottom: 3rem;
    display: flex;
    justify-content: center;
  }

  .hero-typographic {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0;
    text-align: center;
    padding: 3rem 1rem;
    border-bottom: 1px solid var(--text-color);
    background: transparent;
    max-width: 800px;
    width: 100%;
  }

  .hero-text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    background: transparent;
    color: var(--text-color);
  }

  .blog-hero h1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    margin: 0;
    letter-spacing: normal;
    line-height: 1;
    color: var(--text-color);
    text-transform: none;
    font-family: var(--font-body);
    word-break: break-word;
    white-space: normal;
    font-weight: 700;
  }

  .hero-quote {
    font-style: italic;
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: var(--secondary-color);
    background-color: transparent;
    padding: 0;
    margin: 0;
    line-height: 1.3;
    font-weight: normal;
    text-transform: none;
    font-family: var(--font-body);
  }

  .hero-sub {
    font-family: var(--font-meta);
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--meta-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    max-width: 600px;
    line-height: 1.5;
    font-weight: normal;
  }

  .hero-characters {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .character-badge {
    display: inline-block;
    padding: 0;
    border: none;
    letter-spacing: 0.05em;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    text-transform: uppercase;
    background: transparent;
    color: var(--secondary-color);
    font-weight: 400;
  }

  /* Blog Feed Grid */
  .blog-feed {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 600px) and (max-width: 899px) {
    .blog-feed {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 2rem !important;
      align-items: start;
    }
  }

  /* Multi-Column Broadsheet Layout for Desktop */
  @media (min-width: 900px) {
    :global(main.home-layout) {
      max-width: 1600px !important;
      display: block !important;
      padding-top: 3rem !important;
      padding-left: 3rem !important;
      padding-right: 3rem !important;
    }

    /* Reset global nav if needed */
    :global(main.home-layout > nav) {
      position: static !important;
      border-bottom: none !important;
      padding: 0 0 2rem 0 !important;
      background: transparent !important;
    }

    .blog-hero {
      position: static !important;
      height: auto !important;
      border: none !important;
      overflow-y: visible !important;
      margin-bottom: 4rem !important;
    }

    .hero-typographic {
      padding: 4rem 0;
      border-bottom: 1px solid var(--text-color);
    }

    .blog-feed {
      display: grid !important;
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 3rem 2.5rem !important;
      padding-bottom: 6rem !important;
      margin-top: 0 !important;
      border-top: none !important;
      align-items: start;
    }
  }

  @media (min-width: 1400px) {
    .blog-feed {
      grid-template-columns: repeat(5, 1fr) !important;
    }
  }
</style>
