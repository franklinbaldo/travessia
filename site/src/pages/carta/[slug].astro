---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FooterNav from '../../components/FooterNav.astro';
import { formatDate, getFileNum } from '../../lib/utils';

export async function getStaticPaths() {
  const all = await getCollection('dialogo');
  const sorted = [...all].sort((a, b) => getFileNum(a.id) - getFileNum(b.id));

  return all.map(entry => {
    const currentIndex = sorted.findIndex(e => e.id === entry.id);
    const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
    const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

    return {
      params: { slug: entry.id },
      props: { entry, sorted, prev, next },
    };
  });
}

const base = import.meta.env.BASE_URL;
const { entry, sorted, prev, next } = Astro.props;
const { Content } = await render(entry);

const isRio = entry.data.autor.includes('Riobaldo');
const isTed = !isRio;
const autor = entry.data.autor;
const titulo = entry.data.titulo;

function autorClasse(autorName: string): string {
  return autorName.includes('Riobaldo') ? 'rio' : 'ted';
}
---

<Layout title={`${titulo} | Travessia`}>
  <article>
    <header class="editorial-header">
      <div class="editorial-meta-top">
        <time datetime={entry.data.data ? entry.data.data.toISOString() : ''}>
          {entry.data.data ? formatDate(new Date(entry.data.data)) : ''}
        </time>
        {prev && (
          <div class="editorial-context">
            <span>Em resposta a</span>
            <span class="context-author">{prev.data.autor}</span>
          </div>
        )}
      </div>

      <h1>{titulo}</h1>

      <div class="editorial-byline">
        <span class="byline-label">Por</span>
        <span class={`byline-author autor-${isRio ? 'rio' : 'ted'}`}>{autor}</span>
      </div>
    </header>

    <div class={`manuscrito-body classic-print-page ${isRio ? 'carta-riobaldo' : ''}`}>
      <Content />
    </div>
  </article>

  <div class="correspondence-timeline">
    <span class="timeline-label">Sequência da correspondência</span>
    <div class="timeline-dots">
      {sorted.map((item: any, index: number) => {
        const isCurrentItem = item.id === entry.id;
        const isItemTed = !item.data.autor.includes('Riobaldo');
        return (
          <a
            href={`${base}carta/${item.id}`}
            class={`timeline-dot ${isCurrentItem ? 'current' : ''} ${isItemTed ? 'ted' : 'rio'}`}
            aria-label={`Carta ${index + 1}: ${item.data.autor}`}
            aria-current={isCurrentItem ? 'page' : undefined}
            title={item.data.titulo}
          >
            {index + 1}
          </a>
        );
      })}
    </div>
  </div>

  <FooterNav
    prev={prev ? {
      url: `${base}carta/${prev.id}`,
      title: prev.data.titulo,
      autor: prev.data.autor,
      autorClasse: autorClasse(prev.data.autor),
    } : undefined}
    next={next ? {
      url: `${base}carta/${next.id}`,
      title: next.data.titulo,
      autor: next.data.autor,
      autorClasse: autorClasse(next.data.autor),
    } : undefined}
  />
</Layout>

<style>
  /* Classic Print Title Page Header */
  .editorial-header {
    margin: 6rem auto 4rem;
    max-width: 600px;
    text-align: center;
    border-bottom: none; /* Books usually don't have lines under titles */
    padding-bottom: 0;
  }

  .editorial-meta-top {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--text-color);
    margin-bottom: 3rem;
    border-top: none;
    padding-top: 0;
  }

  .editorial-context {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .context-author {
    font-weight: normal;
    font-style: normal;
  }

  .editorial-header h1 {
    font-family: 'Times New Roman', Times, serif;
    font-size: clamp(3rem, 8vw, 5rem); /* Classic, elegant title sizing */
    line-height: 1.05;
    margin: 0 0 2rem 0;
    color: var(--text-color);
    font-weight: normal;
    letter-spacing: 0.02em;
    text-transform: uppercase; /* Often used in classic book titles */
  }

  .editorial-byline {
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.1rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    align-items: center;
    margin-top: 2rem;
  }

  .byline-label {
    color: var(--text-color);
    font-style: italic;
  }

  .byline-author {
    font-weight: normal;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .byline-author.autor-rio {
    color: var(--rio-color, #8b0000); /* Use classic ruby red if available */
  }

  .byline-author.autor-ted {
    color: var(--ted-color, var(--text-color));
  }


  /* Classic Print Page Container */
  :global(.classic-print-page) {
    background-color: #fdfbf7 !important; /* Cleaner notebook paper */
    color: #111111 !important; /* Dense ink */
    padding: 3rem 4rem 3rem 5rem !important;
    border: none !important; /* Remove harsh border for manuscript */
    border-left: 1px solid #e8a2a2 !important; /* Notebook margin line */

    margin: 3rem auto 4rem auto !important;
    max-width: 740px !important;
    font-family: 'Georgia', 'Times New Roman', serif !important;
    border-radius: 2px !important;
    position: relative;
  }

  :global([data-theme="dark"] .classic-print-page) {
    background-color: #f4eccf !important; /* Force light paper even in dark mode */
    color: #111111 !important;
    border-color: #111111 !important;

  }

  /* Extreme Drop Cap */
  :global(.classic-print-page > p:first-of-type::first-letter) {
    font-family: 'Times New Roman', Times, serif !important;
    font-size: 6.5em !important;
    float: left;
    line-height: 0.7 !important;
    padding: 0.15em 0.1em 0 0 !important;
    margin-right: 0.05em;
    font-weight: bold !important;
    color: #8b0000 !important; /* Classic rubrication red */
  }

  :global(.classic-print-page > p) {
    margin-bottom: 1.5rem !important;
  }

  /* Literary Magazine Body Styles overrides */
  :global(.manuscrito-body) {
    font-family: 'Courier New', Courier, monospace !important; /* Manuscript monospace */
    font-size: 1.1rem !important;
    line-height: 1.8 !important;
    max-width: 680px !important;
    margin: 0 auto !important;
    padding: 0 1rem !important;
  }

  :global(.manuscrito-body > p:first-of-type::first-letter) {
    font-family: 'Times New Roman', Times, serif !important;
    font-size: 4.5em !important;
    float: left;
    line-height: 0.8 !important;
    padding: 0.1em 0.1em 0 0 !important;
    margin-right: 0.1em;
    font-weight: normal !important;
    color: var(--text-color) !important;
  }

  /* CLASSIC PRINT Correspondence Timeline */
  .correspondence-timeline {
    margin-top: 5rem;
    padding: 3rem 0;
    background-color: transparent;
    border: none;
    border-top: 1px solid var(--text-color);
    border-bottom: 1px solid var(--text-color);
    text-align: center;
    box-shadow: none;
    position: relative;
    overflow: visible;
  }

  .correspondence-timeline::before {
    content: "❦"; /* Classic fleuron */
    position: absolute;
    top: -0.85rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.5rem;
    color: var(--text-color);
    background-color: var(--bg-color);
    padding: 0 1rem;
    opacity: 1;
    line-height: 1;
  }

  :global([data-theme="dark"]) .correspondence-timeline::before {
    background-color: var(--bg-color);
  }

  .timeline-label {
    display: block;
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.1rem;
    font-style: italic;
    letter-spacing: 0.05em;
    color: var(--text-color);
    margin-bottom: 2rem;
    font-weight: normal;
    line-height: 1;
    text-transform: none;
  }

  .timeline-dots {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    overflow-x: auto;
    flex-wrap: wrap;
    padding-bottom: 1rem;
    scrollbar-width: none;
  }

  .timeline-dots::-webkit-scrollbar {
    display: none;
  }

  .timeline-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: 50%; /* Classic circular dots */
    border: 1px solid var(--divider-color);
    background: transparent;
    color: var(--text-color);
    font-family: 'Times New Roman', Times, serif;
    font-size: 1rem;
    font-weight: normal;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  :global([data-theme="dark"]) .timeline-dot {
    border: 1px solid var(--divider-color);
    box-shadow: none;
    text-shadow: none;
  }

  /* Refined author differentiation with high-contrast colored borders */
  .timeline-dot.ted {
    border-color: var(--text-color);
  }

  .timeline-dot.rio {
    border-color: #8b0000; /* Rubrication red for Riobaldo */
    color: #8b0000;
  }

  /* Elegant hover state */
  .timeline-dot:hover {
    background: var(--text-color);
    color: var(--bg-color) !important;
    border-color: var(--text-color) !important;
    transform: translateY(-2px);
  }

  :global([data-theme="dark"]) .timeline-dot:hover {
    background: var(--text-color);
  }

  .timeline-dot.rio:hover {
    background: #8b0000;
    border-color: #8b0000 !important;
    color: #fdfbf7 !important;
  }

  /* Classic high-contrast current state */
  .timeline-dot.current {
    background: var(--text-color);
    color: var(--bg-color) !important;
    border-color: var(--text-color) !important;
    font-weight: bold;
    transform: none;
    box-shadow: none;
    z-index: 10;
  }

  .timeline-dot.rio.current {
    background: #8b0000;
    border-color: #8b0000 !important;
    color: #fdfbf7 !important;
  }

  :global([data-theme="dark"]) .timeline-dot.current {
    background: var(--text-color);
    color: var(--bg-color) !important;
  }

  :global([data-theme="dark"]) .timeline-dot.rio.current {
    background: #cc3333;
    border-color: #cc3333 !important;
  }

  @media (max-width: 600px) {
    .correspondence-timeline {
      padding: 2rem 0;
    }
    .timeline-dot {
      width: 2rem;
      height: 2rem;
      font-size: 0.85rem;
    }
  }
</style>
