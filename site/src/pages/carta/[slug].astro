---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FooterNav from '../../components/FooterNav.astro';
import { formatDate, getFileNum } from '../../lib/utils';

export async function getStaticPaths() {
  const all = await getCollection('dialogo');
  const sorted = [...all].sort((a, b) => getFileNum(a.id) - getFileNum(b.id));

  return all.map(entry => {
    const currentIndex = sorted.findIndex(e => e.id === entry.id);
    const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
    const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

    return {
      params: { slug: entry.id },
      props: { entry, sorted, prev, next },
    };
  });
}

const base = import.meta.env.BASE_URL;
const { entry, sorted, prev, next } = Astro.props;
const { Content } = await render(entry);

const isRio = entry.data.autor.includes('Riobaldo');
const isTed = !isRio;
const autor = entry.data.autor;
const titulo = entry.data.titulo;

function autorClasse(autorName: string): string {
  return autorName.includes('Riobaldo') ? 'rio' : 'ted';
}
---

<Layout title={`${titulo} | Travessia`}>
  <article>
    <header class="editorial-header">
      <div class="editorial-meta-top">
        <time datetime={entry.data.data ? entry.data.data.toISOString() : ''}>
          {entry.data.data ? formatDate(new Date(entry.data.data)) : ''}
        </time>
        {prev && (
          <div class="editorial-context">
            <span>Em resposta a</span>
            <span class="context-author">{prev.data.autor}</span>
          </div>
        )}
      </div>

      <h1>{titulo}</h1>

      <div class="editorial-byline">
        <span class="byline-label">Por</span>
        <span class={`byline-author autor-${isRio ? 'rio' : 'ted'}`}>{autor}</span>
      </div>
    </header>

    <div class={`manuscrito-body classic-print-page ${isRio ? 'carta-riobaldo' : ''}`}>
      <Content />
    </div>
  </article>

  <div class="correspondence-timeline">
    <span class="timeline-label">Sequência da correspondência</span>
    <div class="timeline-dots">
      {sorted.map((item: any, index: number) => {
        const isCurrentItem = item.id === entry.id;
        const isItemTed = !item.data.autor.includes('Riobaldo');
        return (
          <a
            href={`${base}carta/${item.id}`}
            class={`timeline-dot ${isCurrentItem ? 'current' : ''} ${isItemTed ? 'ted' : 'rio'}`}
            aria-label={`Carta ${index + 1}: ${item.data.autor}`}
            aria-current={isCurrentItem ? 'page' : undefined}
            title={item.data.titulo}
          >
            {index + 1}
          </a>
        );
      })}
    </div>
  </div>

  <FooterNav
    prev={prev ? {
      url: `${base}carta/${prev.id}`,
      title: prev.data.titulo,
      autor: prev.data.autor,
      autorClasse: autorClasse(prev.data.autor),
    } : undefined}
    next={next ? {
      url: `${base}carta/${next.id}`,
      title: next.data.titulo,
      autor: next.data.autor,
      autorClasse: autorClasse(next.data.autor),
    } : undefined}
  />
</Layout>

<style>
  /* Editorial Magazine Header */
  .editorial-header {
    margin: 4rem auto 3rem;
    max-width: 800px;
    text-align: left;
    border-bottom: 1px solid var(--text-color);
    padding-bottom: 2rem;
  }

  .editorial-meta-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-meta);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--meta-color);
    margin-bottom: 2rem;
    border-top: 1px solid var(--text-color);
    padding-top: 0.5rem;
  }

  .editorial-context {
    display: flex;
    gap: 0.5rem;
  }

  .context-author {
    font-weight: 700;
    color: var(--text-color);
  }

  .editorial-header h1 {
    font-family: 'Times New Roman', Times, serif; /* Magazine serif feel */
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    font-weight: normal;
    letter-spacing: -0.02em;
  }

  .editorial-byline {
    font-family: var(--font-meta);
    font-size: 0.9rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .byline-label {
    color: var(--meta-color);
    font-style: italic;
  }

  .byline-author {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .byline-author.autor-rio {
    color: var(--secondary-color);
  }

  .byline-author.autor-ted {
    color: var(--text-color);
  }


  /* Classic Print Page Container */
  :global(.classic-print-page) {
    background-color: #f4eccf !important; /* Aged paper */
    color: #111111 !important; /* Dense ink */
    padding: 3rem 4rem !important;
    border: 1px solid #111111 !important;

    margin: 3rem auto 4rem auto !important;
    max-width: 740px !important;
    font-family: 'Georgia', 'Times New Roman', serif !important;
    border-radius: 2px !important;
    position: relative;
  }

  :global([data-theme="dark"] .classic-print-page) {
    background-color: #f4eccf !important; /* Force light paper even in dark mode */
    color: #111111 !important;
    border-color: #111111 !important;

  }

  /* Extreme Drop Cap */
  :global(.classic-print-page > p:first-of-type::first-letter) {
    font-family: 'Times New Roman', Times, serif !important;
    font-size: 6.5em !important;
    float: left;
    line-height: 0.7 !important;
    padding: 0.15em 0.1em 0 0 !important;
    margin-right: 0.05em;
    font-weight: bold !important;
    color: #8b0000 !important; /* Classic rubrication red */
  }

  :global(.classic-print-page > p) {
    margin-bottom: 1.5rem !important;
  }

  /* Literary Magazine Body Styles overrides */
  :global(.manuscrito-body) {
    font-family: 'Times New Roman', Times, serif !important; /* Force serif for body */
    font-size: 1.25rem !important;
    line-height: 1.7 !important;
    max-width: 680px !important;
    margin: 0 auto !important;
    padding: 0 1rem !important;
  }

  :global(.manuscrito-body > p:first-of-type::first-letter) {
    font-family: 'Times New Roman', Times, serif !important;
    font-size: 4.5em !important;
    float: left;
    line-height: 0.8 !important;
    padding: 0.1em 0.1em 0 0 !important;
    margin-right: 0.1em;
    font-weight: normal !important;
    color: var(--text-color) !important;
  }

  /* BRUTALIST Correspondence Timeline */
  .correspondence-timeline {
    margin-top: 5rem;
    padding: 4rem 2rem;
    background-color: var(--text-color); /* Deep ink background */
    border: none;
    border-left: 12px solid var(--accent-color); /* Aggressive magazine-spine border */
    text-align: left;
    box-shadow: -15px 15px 0 var(--meta-color); /* Heavy solid shadow simulating physical depth */
    position: relative;
    overflow: hidden;
  }

  .correspondence-timeline::before {
    content: "ARQUIVO";
    position: absolute;
    top: -1rem;
    right: -1rem;
    font-family: var(--font-meta);
    font-size: 8rem;
    font-weight: 900;
    color: var(--bg-color);
    opacity: 0.05;
    pointer-events: none;
    transform: rotate(-10deg);
  }

  .timeline-label {
    display: block;
    font-family: var(--font-meta);
    font-size: clamp(1.5rem, 4vw, 2.5rem); /* Massive bold label */
    text-transform: uppercase;
    letter-spacing: -0.05em; /* Brutalist tight tracking */
    color: var(--bg-color); /* Bright inverted text */
    margin-bottom: 2rem;
    font-weight: 900;
    line-height: 1;
  }

  .timeline-dots {
    display: flex;
    justify-content: flex-start;
    gap: 1rem;
    overflow-x: auto;
    flex-wrap: wrap; /* Let it flow wildly as a grid */
    padding-bottom: 1rem;
    scrollbar-width: none;
  }

  .timeline-dots::-webkit-scrollbar {
    display: none;
  }

  .timeline-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem; /* Massive interactive blocks */
    height: 3.5rem;
    flex-shrink: 0;
    border-radius: 0; /* Strict squares */
    border: 3px solid var(--bg-color); /* High contrast border against dark bg */
    background: transparent;
    color: var(--bg-color);
    font-family: var(--font-meta);
    font-size: 1.25rem; /* Huge unmissable numbers */
    font-weight: 900;
    text-decoration: none;
    transition: none; /* No smooth easing. Pure instant brutalist state changes. */
  }

  :global([data-theme="dark"]) .timeline-dot {
    border: 3px solid var(--bg-color);
    box-shadow: none;
    text-shadow: none;
  }

  /* Extreme author differentiation purely by bold color blocks */
  .timeline-dot.ted {
    border-color: var(--meta-color);
    color: var(--bg-color); /* Fix contrast by making text bright */
  }

  .timeline-dot.rio {
    border-color: var(--secondary-color);
    color: var(--bg-color); /* Fix contrast by making text bright */
  }

  /* Aggressive spatial shift and color inversion on hover */
  .timeline-dot:hover {
    transform: translate(-5px, -5px);
    background: var(--text-color); /* Deep ink background instead of shocking red */
    color: var(--bg-color) !important; /* White paper text */
    border-color: var(--text-color) !important;
    box-shadow: 5px 5px 0 var(--accent-color); /* Red shadow for the brutalist accent */
  }

  :global([data-theme="dark"]) .timeline-dot:hover {
    background: var(--text-color);
    box-shadow: 5px 5px 0 var(--accent-color);
  }

  /* Dominating current state */
  .timeline-dot.current {
    background: var(--bg-color); /* Solid inverted block */
    color: var(--text-color) !important;
    border-color: var(--bg-color) !important;
    font-weight: 900;
    transform: scale(1.15) rotate(-3deg); /* Break the grid alignment aggressively */
    box-shadow: 6px 6px 0 var(--accent-color); /* Blaring red shadow */
    z-index: 10;
    position: relative; /* Fix clipping issue for the rotated element */
  }

  :global([data-theme="dark"]) .timeline-dot.current {
    background: var(--bg-color);
    color: var(--text-color) !important;
  }

  @media (max-width: 600px) {
    .correspondence-timeline {
      padding: 2rem 1rem;
    }
    .timeline-dot {
      width: 3rem;
      height: 3rem;
      font-size: 1rem;
    }
  }
</style>
