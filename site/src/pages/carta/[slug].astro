---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FooterNav from '../../components/FooterNav.astro';
import { formatDate, getFileNum } from '../../lib/utils';

export async function getStaticPaths() {
  const all = await getCollection('dialogo');
  const sorted = [...all].sort((a, b) => getFileNum(a.id) - getFileNum(b.id));

  return all.map(entry => {
    const currentIndex = sorted.findIndex(e => e.id === entry.id);
    const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
    const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

    return {
      params: { slug: entry.id },
      props: { entry, sorted, prev, next },
    };
  });
}

const base = import.meta.env.BASE_URL;
const { entry, sorted, prev, next } = Astro.props;
const { Content } = await render(entry);

const isRio = entry.data.autor.includes('Riobaldo');
const isTed = !isRio;
const autor = entry.data.autor;
const titulo = entry.data.titulo;

function autorClasse(autorName: string): string {
  return autorName.includes('Riobaldo') ? 'rio' : 'ted';
}
---

<Layout title={`${titulo} | Travessia`}>
  <article>
    <header class="editorial-header">
      <div class="editorial-meta-top">
        <time datetime={entry.data.data ? entry.data.data.toISOString() : ''}>
          {entry.data.data ? formatDate(new Date(entry.data.data)) : ''}
        </time>
        {prev && (
          <div class="editorial-context">
            <span>Em resposta a</span>
            <span class="context-author">{prev.data.autor}</span>
          </div>
        )}
      </div>

      <h1>{titulo}</h1>

      <div class="editorial-byline">
        <span class="byline-label">Por</span>
        <span class={`byline-author autor-${isRio ? 'rio' : 'ted'}`}>{autor}</span>
      </div>
    </header>

    <div class={`manuscrito-body classic-print-page ${isRio ? 'carta-riobaldo' : ''}`}>
      <Content />
    </div>
  </article>

  <div class="correspondence-timeline">
    <span class="timeline-label">Sequência da correspondência</span>
    <div class="timeline-dots">
      {sorted.map((item: any, index: number) => {
        const isCurrentItem = item.id === entry.id;
        const isItemTed = !item.data.autor.includes('Riobaldo');
        return (
          <a
            href={`${base}carta/${item.id}`}
            class={`timeline-dot ${isCurrentItem ? 'current' : ''} ${isItemTed ? 'ted' : 'rio'}`}
            aria-label={`Carta ${index + 1}: ${item.data.autor}`}
            aria-current={isCurrentItem ? 'page' : undefined}
            title={item.data.titulo}
          >
            {index + 1}
          </a>
        );
      })}
    </div>
  </div>

  <FooterNav
    prev={prev ? {
      url: `${base}carta/${prev.id}`,
      title: prev.data.titulo,
      autor: prev.data.autor,
      autorClasse: autorClasse(prev.data.autor),
    } : undefined}
    next={next ? {
      url: `${base}carta/${next.id}`,
      title: next.data.titulo,
      autor: next.data.autor,
      autorClasse: autorClasse(next.data.autor),
    } : undefined}
  />
</Layout>

<style>
    /* Editorial Magazine Header - High Contrast Contemporary */
  .editorial-header {
    margin: 4rem auto 3rem;
    max-width: 65ch;
    text-align: left;
    border-bottom: 3px double var(--text-color);
    padding-bottom: 2rem;
    background-color: transparent;
    color: var(--text-color);
  }

  .editorial-header > div, .editorial-header > h1 {
    max-width: 100%;
    margin-left: 0;
    margin-right: 0;
  }

  .editorial-meta-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: 0.95rem;
    text-transform: none;
    letter-spacing: 0.02em;
    color: var(--text-color);
    margin-bottom: 2rem;
    border-top: 1px solid var(--text-color);
    padding-top: 0.5rem;
  }

  .editorial-context {
    display: flex;
    gap: 0.5rem;
  }

  .context-author {
    font-weight: 400;
    font-style: italic;
    color: var(--text-color);
  }

  .editorial-header h1 {
    font-family: var(--font-body);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-align: left;
  }

  .editorial-byline {
    font-family: var(--font-body);
    font-size: 1.25rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    border: none;
    padding: 0;
    display: inline-flex;
    font-style: italic;
  }

  .byline-label {
    color: var(--text-color);
    font-weight: normal;
  }

  .byline-author {
    font-weight: normal;
    text-transform: none;
    letter-spacing: normal;
  }

  .byline-author.autor-rio {
    color: var(--text-color);
  }

  .byline-author.autor-ted {
    color: var(--text-color);
  }

  /* Structural Manuscript Theme - No Skeuomorphism */
  :global(.classic-print-page) {
    background-color: transparent !important;
    color: var(--text-color) !important;
    padding: 0 5% 0 20% !important;
    border-left: 4px solid var(--accent-color) !important;
    margin: 4rem 0 6rem 5% !important;
    max-width: 100% !important;
    font-family: var(--font-body) !important;
    position: relative;
  }

  @media (max-width: 600px) {
    :global(.classic-print-page) {
      padding: 0 1rem 0 3rem !important;
      margin-left: 1rem !important;
      border-left: 2px solid var(--accent-color) !important;
      max-width: 100% !important;
    }
  }

  /* Classic Typography -> Let global.css handle it now */


  /* Classic Print Typography Integration */
  /* Contemporary Literary Magazine Theme */
  :global(.manuscrito-body) {
    display: block;
    width: 100%;
    max-width: 100% !important;
    margin: 0 !important;
    position: relative;
    padding: 0 0 2rem 0 !important;
    background-color: transparent !important;
    background-image: repeating-linear-gradient(
      transparent,
      transparent 1.95rem,
      var(--divider-color) 1.95rem,
      var(--divider-color) 2rem
    ) !important;
    border: none !important;
    box-shadow: none !important;
  }

  /* Remove notebook margin line */
  :global(.manuscrito-body)::before {
    display: none;
  }

  /* Ensure text sits gracefully */
  :global(.manuscrito-body > *) {
    position: relative;
    z-index: 1;
    background-color: transparent !important;
  }

    /* Refined paragraph presentation - Early Print Folio */
  :global(.manuscrito-body p) {
    text-indent: 0 !important;
    max-width: 75ch !important;
    text-align: left !important;
    background-color: transparent !important;
    margin-bottom: 2rem !important;
    color: var(--text-color) !important;
    line-height: 2rem !important;
    letter-spacing: -0.01em !important;
    word-spacing: normal !important;
    hyphens: auto !important;
  }

  :global(.manuscrito-body p:first-of-type) {
    text-indent: 0 !important;
    margin-top: 2rem !important;
  }

  /* Massive Drop Cap - First Paragraph Only */
  :global(.manuscrito-body p:first-of-type::first-letter) {
    float: none;
    font-size: inherit;
    line-height: inherit;
    padding: 0;
    color: inherit;
    font-family: inherit;
    font-weight: inherit;
  }

  /* Reset other first letters */
  :global(.manuscrito-body p:not(:first-of-type)::first-letter) {
    color: inherit;
    font-weight: normal;
    font-size: inherit;
  }

  /* Elegant Blockquote */
  :global(.manuscrito-body blockquote) {
    background-color: var(--sand-bg) !important;
    border-left: 10px solid var(--accent-color) !important;
    margin: 2rem -2rem 2rem 0 !important;
    padding: 1rem 2rem !important;
    box-shadow: -10px 10px 0 var(--meta-color) !important;
    font-style: italic;
    color: var(--text-color) !important;
  }

  :global([data-theme="dark"] .manuscrito-body blockquote) {
    background-color: transparent !important;
    box-shadow: -10px 10px 0 var(--text-color) !important;
  }

/* === MANUSCRITO TIMELINE - MICROINTERAÇÕES E DETALHES === */
  .correspondence-timeline {
    margin-top: 5rem;
    padding: 3rem 0;
    background-color: transparent;
    border: none;
    border-top: 1px solid var(--divider-color);
    text-align: left;
    position: relative;
  }



  .timeline-label {
    display: inline-block;
    font-family: var(--font-meta);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--meta-color);
    margin-bottom: 2rem;
    font-weight: normal;
    background-color: transparent;
    padding: 0;
    position: relative;
    z-index: 2;
  }

  .timeline-dots {
    display: flex;
    justify-content: flex-start;
    gap: 1.5rem;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 2rem;
    padding-top: 1.5rem; /* Add padding to prevent clipping of the current scale and rotation */
    scrollbar-width: thin;
    position: relative;
    z-index: 2;
  }

  .timeline-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: 50%; /* Estilo carimbo/marcação */
    border: 2px solid var(--text-color);
    background: transparent;
    color: var(--text-color);
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
  }

  /* Microinteração de linha conectando as marcações estilo esboço */


  .timeline-dot.ted {
    border-color: var(--text-color);
    color: var(--text-color);
  }

  .timeline-dot.rio {
    border-color: var(--accent-color);
    color: var(--accent-color);
  }

  /* Microinterações detalhadas de Hover */
  .timeline-dot:hover {
    transform: scale(1.1) translateY(-2px);
    background-color: var(--bg-color);
    box-shadow: 2px 2px 0 var(--text-color);
    border-radius: 0;
  }

  .timeline-dot.ted:hover {
    border-color: var(--meta-color);
    color: var(--bg-color);
    background-color: var(--meta-color);
  }

  .timeline-dot.rio:hover {
    background-color: var(--accent-color);
    color: var(--bg-color);
    box-shadow: 2px 2px 0 var(--accent-color);
  }

  /* Estado ativo/corrente como um círculo preenchido de forma imperfeita */
  .timeline-dot.current {
    background: transparent;
    color: var(--bg-color) !important;
    border-color: transparent;
    font-weight: 700;
    transform: scale(1.1);
    border-radius: 0;
    background-color: var(--text-color);
    z-index: 10;
  }

  /* Apply the actual background correctly specifically for current to prevent leak */









  @media (max-width: 600px) {
    .correspondence-timeline {
      padding: 2rem 1rem;
    }
    .timeline-dot {
      width: 2rem;
      height: 2rem;
      font-size: 0.9rem;
    }
    .timeline-dots::before {
      top: 2.5rem;
    }
  }
</style>