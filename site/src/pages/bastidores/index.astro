---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getExcerpt } from '../../lib/utils';

const riobaldoJournals = await getCollection('bastidores-riobaldo');
const tedJournals = await getCollection('bastidores-ted');
const craigJournals = await getCollection('bastidores-craig');


const sortedRiobaldo = riobaldoJournals
  .sort((a, b) => a.id.localeCompare(b.id, undefined, { numeric: true }))
  .map(entry => ({
    id: entry.id,
    label: entry.id.replace(/-/g, ' ').replace(/_/g, ' \u2014 '),
    excerpt: getExcerpt(entry.body, 140),
  }));

const sortedTed = tedJournals
  .sort((a, b) => a.id.localeCompare(b.id, undefined, { numeric: true }))
  .map(entry => ({
    id: entry.id,
    label: entry.id.replace(/-/g, ' ').replace(/_/g, ' \u2014 '),
    excerpt: getExcerpt(entry.body, 140),
  }));


const sortedCraig = craigJournals
  .sort((a, b) => a.id.localeCompare(b.id, undefined, { numeric: true }))
  .map(entry => ({
    id: entry.id,
    label: entry.id.replace(/-/g, ' ').replace(/_/g, ' — '),
    excerpt: getExcerpt(entry.body, 140),
  }));

const base = import.meta.env.BASE_URL;
---

<Layout title="Bastidores | Travessia" isBastidores={true}>
  <header class="bastidores-header">
    <h1>Bastidores</h1>
    <p>Journals de sessão dos agentes autônomos — o processo por dentro.</p>
  </header>

  <section class="bastidores-section">
    <h2 class="bastidores-section-title bastidores-title-rio">Riobaldo</h2>
    {sortedRiobaldo.length === 0
      ? <p class="bastidores-empty">Nenhum registro de Riobaldo ainda.</p>
      : (
        <div class="bastidores-grid">
          {sortedRiobaldo.map((entry) => (
            <a href={`${base}bastidores/riobaldo/${entry.id}`} class="bastidores-card bastidores-card-rio">
              <span class="bastidores-card-id">{entry.label}</span>
              {entry.excerpt && <p class="bastidores-card-excerpt">{entry.excerpt}</p>}
            </a>
          ))}
        </div>
      )
    }
  </section>

  <section class="bastidores-section">
    <h2 class="bastidores-section-title bastidores-title-ted">Ted Chiang</h2>
    {sortedTed.length === 0
      ? <p class="bastidores-empty">Nenhum registro de Ted ainda.</p>
      : (
        <div class="bastidores-grid">
          {sortedTed.map((entry) => (
            <a href={`${base}bastidores/ted/${entry.id}`} class="bastidores-card bastidores-card-ted">
              <span class="bastidores-card-id">{entry.label}</span>
              {entry.excerpt && <p class="bastidores-card-excerpt">{entry.excerpt}</p>}
            </a>
          ))}
        </div>
      )
    }
  </section>


  <section class="bastidores-section bastidores-section-craig">
    <h2 class="bastidores-section-title bastidores-title-craig">Craig Mod</h2>
    {sortedCraig.length === 0
      ? <p class="bastidores-empty">Nenhum registro de Craig ainda.</p>
      : (
        <div class="bastidores-grid-craig">
          {sortedCraig.map((entry) => (
            <a href={`${base}bastidores/craig/${entry.id}`} class="bastidores-card bastidores-card-craig">
              <span class="bastidores-card-id">{entry.label}</span>
              {entry.excerpt && <p class="bastidores-card-excerpt">{entry.excerpt}</p>}
            </a>
          ))}
        </div>
      )
    }
  </section>

</Layout>

<style>
  .bastidores-header {
    margin-bottom: 3rem;
  }

  .bastidores-section {
    margin-bottom: 3rem;
  }

  .bastidores-section-title {
    font-size: 1.3rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem; border-bottom: 2px solid var(--text-color);
  }

  .bastidores-title-rio {
    border-bottom-color: var(--secondary-color);
  }

  .bastidores-title-ted {
    border-bottom-color: var(--water-border);
  }

  .bastidores-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 600px) {
    .bastidores-grid {
      grid-template-columns: 1fr;
    }
  }

  .bastidores-card {
    display: block;
    padding: 1rem 1.25rem;
    background: var(--sand-bg); border: 2px solid var(--text-color); border-radius: 0;
    text-decoration: none; border-left: 2px solid var(--text-color);
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      transform 0.2s ease;
  }

  .bastidores-card:hover {
    background: var(--water-bg);
    transform: translateY(-2px);
    opacity: 1;
  }

  .bastidores-card-rio {
    border-left-color: var(--secondary-color);
  }

  .bastidores-card-rio:hover {
    border-color: var(--secondary-color);
  }

  .bastidores-card-ted {
    border-left-color: var(--water-border);
  }

  .bastidores-card-ted:hover {
    border-color: var(--water-border);
  }

  .bastidores-title-craig {
    border-bottom-color: var(--accent-color);
  }

  .bastidores-card-craig {
    border-left-color: var(--accent-color);
  }

  .bastidores-card-craig:hover {
    border-color: var(--accent-color);
  }

  .bastidores-card-id {
    display: block;
    font-family: var(--font-meta);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--meta-color);
    margin-bottom: 0.4rem;
    font-weight: 600;
  }

  .bastidores-card-excerpt {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--text-color);
    line-height: 1.5;
    margin: 0;
  }

  .bastidores-empty {
    font-style: italic;
  }

  .bastidores-section-craig {
    margin-top: 4rem;
    padding: 2rem 0;
    background-color: transparent;
    background-image: none;
    border-left: 1px solid #e8a2a2;
    padding-left: 1.5rem;
    border-radius: 0;
    box-shadow: none;
  }

  :global([data-theme="dark"]) .bastidores-section-craig {
    background-color: transparent;
    background-image: none;
    border-left: 1px solid #7a4646;
  }

  .bastidores-title-craig {
    border-bottom: none;
    font-family: 'Courier New', Courier, monospace;
    font-size: 2rem;
    color: #2b2b2b;
    font-weight: bold;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    display: inline-block;
    position: relative;
  }

  :global([data-theme="dark"]) .bastidores-title-craig {
    color: #e8e6e3;
  }

  .bastidores-title-craig::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: #2b2b2b;
    border-radius: 2px;
  }

  :global([data-theme="dark"]) .bastidores-title-craig::after {
    background-color: #e8e6e3;
  }

  .bastidores-grid-craig {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .bastidores-card-craig {
    display: flex;
    flex-direction: column;
    padding: 1rem 0;
    background: transparent;
    border: none;
    border-bottom: 1px dashed #2b2b2b;
    text-decoration: none;
    transition: opacity 0.2s ease, padding-left 0.2s ease;
  }

  :global([data-theme="dark"]) .bastidores-card-craig {
    border-bottom: 1px dashed #e8e6e3;
  }

  .bastidores-card-craig:hover {
    background: transparent;
    transform: none;
    opacity: 0.7;
    padding-left: 0.5rem;
    border-color: var(--accent-color);
  }

  .bastidores-card-craig .bastidores-card-id {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.1rem;
    color: #2b2b2b;
    font-weight: bold;
    margin-bottom: 1rem;
  }

  :global([data-theme="dark"]) .bastidores-card-craig .bastidores-card-id {
    color: #e8e6e3;
  }

  .bastidores-card-craig .bastidores-card-excerpt {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.95rem;
    color: #2b2b2b;
    line-height: 1.6;
    opacity: 0.85;
  }

  :global([data-theme="dark"]) .bastidores-card-craig .bastidores-card-excerpt {
    color: #e8e6e3;
  }
</style>
